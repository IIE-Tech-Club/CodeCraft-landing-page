---
---
<div class="cursor-container" aria-hidden="true">
  <div id="cursor-dot"></div>
  <div id="cursor-ring"></div>
  <div id="cursor-glow"></div>
</div>

<style is:global>
  /* Hide default cursor only on devices that support hover */
  @media (hover: hover) and (pointer: fine) {
    * {
      cursor: none !important;
    }
  }
</style>

<style>
  .cursor-container {
    display: none; /* Hidden by default */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
  }

  /* Show only on devices that support hover */
  @media (hover: hover) and (pointer: fine) {
    .cursor-container {
      display: block;
    }
  }

  /* Precision Dot */
  #cursor-dot {
    position: fixed;
    width: 6px;
    height: 6px;
    background: #00f2fe;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.3s ease, height 0.3s ease, background 0.3s ease;
    z-index: 10001;
  }

  /* Adaptive Ring */
  #cursor-ring {
    position: fixed;
    width: 34px;
    height: 34px;
    border: 1.5px solid rgba(0, 242, 254, 0.4);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    /* Smooth LERP-like transition for the ring */
    transition: 
      width 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
      height 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
      border-color 0.4s ease,
      background 0.4s ease;
    z-index: 10000;
  }

  /* Techy Crosshair Accents for Ring */
  #cursor-ring::before, #cursor-ring::after {
    content: '';
    position: absolute;
    background: #00f2fe;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Background Ambient Glow */
  #cursor-glow {
    position: fixed;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 242, 254, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  /* Hover States */
  .cursor-hover #cursor-dot {
    width: 4px;
    height: 4px;
    background: #ffffff;
  }

  .cursor-hover #cursor-ring {
    width: 50px;
    height: 50px;
    border-color: rgba(0, 242, 254, 0.8);
    background: rgba(0, 242, 254, 0.05);
  }

  /* Click State */
  .cursor-active #cursor-ring {
    width: 25px;
    height: 25px;
    background: rgba(0, 242, 254, 0.2);
    border-color: #00f2fe;
  }
</style>

<script is:inline>
  const dot = document.getElementById("cursor-dot");
  const ring = document.getElementById("cursor-ring");
  const glow = document.getElementById("cursor-glow");
  const container = document.querySelector(".cursor-container");

  let mouseX = 0;
  let mouseY = 0;
  let ringX = 0;
  let ringY = 0;

  // Smoothing factor for the ring (0.1 = slow/liquid, 1.0 = instant)
  const lerpFactor = 0.15;

  document.addEventListener("pointermove", (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    
    // Dot is instant
    if (dot) {
      dot.style.left = mouseX + "px";
      dot.style.top = mouseY + "px";
    }

    // Glow is instant
    if (glow) {
      glow.style.left = mouseX + "px";
      glow.style.top = mouseY + "px";
      glow.style.opacity = "1";
    }
  });

  // Smooth animation loop for the ring
  function animate() {
    // Linear Interpolation: ring position moves towards mouse position
    ringX += (mouseX - ringX) * lerpFactor;
    ringY += (mouseY - ringY) * lerpFactor;

    if (ring) {
      ring.style.left = ringX + "px";
      ring.style.top = ringY + "px";
    }

    requestAnimationFrame(animate);
  }
  animate();

  // Interaction Listeners
  document.addEventListener("mousedown", () => container?.classList.add("cursor-active"));
  document.addEventListener("mouseup", () => container?.classList.remove("cursor-active"));

  // Detect hover on interactable elements
  const updateHoverState = (isHovering) => {
    if (isHovering) container?.classList.add("cursor-hover");
    else container?.classList.remove("cursor-hover");
  };

  // We use event delegation for better performance
  document.addEventListener("mouseover", (e) => {
    const target = e.target;
    if (target.closest('a, button, [role="button"], input, textarea, .fcard, .podium-card, .org-card')) {
      updateHoverState(true);
    }
  });

  document.addEventListener("mouseout", (e) => {
    const target = e.target;
    if (target.closest('a, button, [role="button"], input, textarea, .fcard, .podium-card, .org-card')) {
      updateHoverState(false);
    }
  });

  document.addEventListener("pointerleave", () => {
    if (glow) glow.style.opacity = "0";
    if (dot) dot.style.opacity = "0";
    if (ring) ring.style.opacity = "0";
  });

  document.addEventListener("pointerenter", () => {
    if (dot) dot.style.opacity = "1";
    if (ring) ring.style.opacity = "1";
  });
</script>
