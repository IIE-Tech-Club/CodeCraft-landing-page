---
import logoImg from "../assets/images/logo-high.png";
---

<header class="nav-root" id="site-nav-container">
  <nav class="nav-inner" id="site-nav" role="navigation" aria-label="Main navigation">

    <!-- Logo -->
    <a href="#home" class="nav-brand" aria-label="CodeCraft – back to top" id="nav-brand-link">
      <img src={logoImg.src} width={logoImg.width} height={logoImg.height} alt="CodeCraft logo" class="nav-logo-img" decoding="async" />
      <div class="nav-brand-text">
        <span class="nav-brand-name">CODE<span class="nav-brand-accent">CRAFT</span></span>
        <span class="nav-brand-sub">IIE Tech Club</span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <nav class="nav-links" aria-label="Sections" id="nav-links-desktop">
      <a href="#about"      class="nav-link" id="nl-about">About</a>
      <a href="#prizes"     class="nav-link" id="nl-prizes">Prizes</a>
      <a href="#timeline"   class="nav-link" id="nl-timeline">Timeline</a>
      <a href="#rules"      class="nav-link" id="nl-rules">Rules</a>
      <a href="#submission" class="nav-link" id="nl-submit">Submit</a>
      <a href="#organizers" class="nav-link" id="nl-team">Team</a>
    </nav>

    <!-- Right side -->
    <div class="nav-right">
      <!-- Active section badge -->
      <span class="nav-section-badge" id="nav-section-badge" aria-live="polite" aria-atomic="true">
        <span class="nav-section-dot" aria-hidden="true"></span>
        <span id="nav-section-label">Home</span>
      </span>

      <!-- Register CTA -->
      <button class="nav-cta" type="button" data-auth-trigger id="nav-register-btn">
        <span>Register</span>
        <svg viewBox="0 0 16 16" fill="none" class="nav-cta-icon" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Hamburger (mobile) -->
      <button class="nav-hamburger" id="hamburger" aria-label="Toggle menu" aria-controls="mobile-menu" aria-expanded="false" type="button">
        <span class="ham-line" id="hl-1"></span>
        <span class="ham-line" id="hl-2"></span>
        <span class="ham-line" id="hl-3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown menu -->
  <div class="nav-mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="nav-mobile-links" aria-label="Mobile navigation">
      <div class="nav-mobile-header">
        <h2 class="nav-mobile-title">CodeCraft</h2>
        <button class="nav-mobile-close" id="mobile-close" aria-label="Close menu" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <div class="nav-mobile-sections">
        <a href="#about"      class="nav-mobile-link" data-close-menu id="ml-about">
          <span class="nav-mobile-num">01</span>
          <span class="nav-mobile-text">About</span>
        </a>
        <a href="#prizes"     class="nav-mobile-link" data-close-menu id="ml-prizes">
          <span class="nav-mobile-num">02</span>
          <span class="nav-mobile-text">Prizes</span>
        </a>
        <a href="#timeline"   class="nav-mobile-link" data-close-menu id="ml-timeline">
          <span class="nav-mobile-num">03</span>
          <span class="nav-mobile-text">Timeline</span>
        </a>
        <a href="#rules"      class="nav-mobile-link" data-close-menu id="ml-rules">
          <span class="nav-mobile-num">04</span>
          <span class="nav-mobile-text">Rules</span>
        </a>
        <a href="#submission" class="nav-mobile-link" data-close-menu id="ml-submit">
          <span class="nav-mobile-num">05</span>
          <span class="nav-mobile-text">Submission</span>
        </a>
        <a href="#organizers" class="nav-mobile-link" data-close-menu id="ml-team">
          <span class="nav-mobile-num">06</span>
          <span class="nav-mobile-text">Team</span>
        </a>
        <a href="#contact"    class="nav-mobile-link" data-close-menu id="ml-contact">
          <span class="nav-mobile-num">07</span>
          <span class="nav-mobile-text">Contact</span>
        </a>

        <div class="nav-mobile-register-spacing">
          <button class="nav-mobile-cta" type="button" data-auth-trigger data-close-menu id="ml-register">
            <span>Register Now</span>
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* ── Root ── */
  .nav-root {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: padding 0.5s cubic-bezier(0.16,1,0.3,1);
    padding: 0;
  }

  /* ── Inner pill ── */
  .nav-inner {
    width: 100%;
    max-width: 1280px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    transition:
      padding 0.5s cubic-bezier(0.16,1,0.3,1),
      background 0.5s ease,
      border-radius 0.5s ease,
      border-color 0.5s ease,
      box-shadow 0.5s ease,
      max-width 0.5s ease;
    border: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    backdrop-filter: none;
  }

  /* scrolled state (toggled via JS) */
  .nav-root.scrolled {
    padding: 0.75rem 1rem;
  }

  .nav-root.scrolled .nav-inner {
    padding: 0.75rem 1.5rem;
    max-width: 1080px;
    background: rgba(3, 8, 18, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 999px;
    border-color: rgba(0, 242, 254, 0.15);
    box-shadow:
      0 0 0 1px rgba(0,242,254,0.06) inset,
      0 20px 60px rgba(0,0,0,0.5),
      0 0 30px rgba(0,242,254,0.06);
  }

  /* ── Brand ── */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(0,242,254,0.45));
    transition: filter 0.3s ease;
  }

  .nav-brand:hover .nav-logo-img {
    filter: drop-shadow(0 0 16px rgba(0,242,254,0.7));
  }

  .nav-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .nav-brand-name {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1.05rem;
    color: #f0f6ff;
    letter-spacing: 0.04em;
  }

  .nav-brand-accent {
    color: #00f2fe;
  }

  .nav-brand-sub {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.5rem;
    color: rgba(100, 116, 139, 0.8);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 0.2rem;
  }

  /* ── Desktop links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #64748b;
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 16px;
    height: 1px;
    background: #00f2fe;
    border-radius: 999px;
    transition: transform 0.25s ease;
  }

  .nav-link:hover {
    color: #f0f6ff;
    background: rgba(255,255,255,0.04);
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .nav-link.is-active {
    color: #00f2fe;
  }

  /* ── Right side ── */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* Section badge */
  .nav-section-badge {
    display: none;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #64748b;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
  }

  .nav-root.scrolled .nav-section-badge {
    display: flex;
  }

  .nav-section-dot {
    width: 5px;
    height: 5px;
    background: #00f2fe;
    border-radius: 50%;
    box-shadow: 0 0 6px #00f2fe;
    animation: dot-pulse 2s infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  /* CTA button */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: linear-gradient(135deg, #00f2fe, #4facfe);
    color: #020811;
    border: none;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,242,254,0.35);
  }

  .nav-cta-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.55rem 0.65rem;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .nav-hamburger:hover {
    background: rgba(255,255,255,0.08);
  }

  .ham-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #f0f6ff;
    border-radius: 999px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* hamburger open state */
  .nav-hamburger.is-open #hl-1 { transform: translateY(6.5px) rotate(45deg); }
  .nav-hamburger.is-open #hl-2 { opacity: 0; transform: scaleX(0); }
  .nav-hamburger.is-open #hl-3 { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Mobile menu ── */
  .nav-mobile-menu {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100vh;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 199;
  }

  .nav-mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
  }

  .nav-mobile-links {
    position: absolute;
    left: 0;
    top: 0;
    height: 100vh;
    width: min(380px, 85vw);
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, rgba(2, 4, 17, 0.98) 0%, rgba(5, 8, 18, 0.98) 100%);
    border-right: 1px solid rgba(0, 242, 254, 0.15);
    padding: 0;
    gap: 0;
    overflow-y: auto;
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(16px);
  }

  .nav-mobile-menu.is-open .nav-mobile-links {
    transform: translateX(0);
  }

  .nav-mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid rgba(0, 242, 254, 0.1);
    gap: 1rem;
    background: linear-gradient(180deg, rgba(0, 242, 254, 0.05) 0%, transparent 100%);
    position: relative;
    overflow: hidden;
  }

  .nav-mobile-header::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(0, 242, 254, 0.3) 50%, transparent 100%);
  }

  .nav-mobile-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #f0f6ff;
    margin: 0;
    letter-spacing: 0.05em;
    text-shadow: 0 0 12px rgba(0, 242, 254, 0.3);
  }

  .nav-mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #f0f6ff;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .nav-mobile-close:hover {
    background: rgba(0, 242, 254, 0.1);
    border-color: rgba(0, 242, 254, 0.3);
    color: #00f2fe;
  }

  .nav-mobile-close svg {
    width: 18px;
    height: 18px;
  }

  .nav-mobile-sections {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 1rem 0;
    flex: 1;
    position: relative;
  }

  .nav-mobile-sections::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, rgba(0, 242, 254, 0.3) 0%, transparent 100%);
  }

  .nav-mobile-register-spacing {
    padding-top: 1.5rem;
    padding-left: 1rem;
    padding-right: 1rem;
    padding-bottom: 1rem;
    border-top: 1px solid rgba(0, 242, 254, 0.1);
    margin-top: 0.5rem;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #64748b;
    text-decoration: none;
    padding: 1.1rem 1.5rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    position: relative;
    overflow: hidden;
  }

  .nav-mobile-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0, 242, 254, 0.08) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  /* Glow effect on hover */
  .nav-mobile-link::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 242, 254, 0.1) 50%,
      transparent 100%
    );
    opacity: 0;
    animation: none;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .nav-mobile-link:hover {
    color: #00f2fe;
    border-left-color: rgba(0, 242, 254, 0.5);
    border-right-color: rgba(0, 242, 254, 0.2);
    background: rgba(0, 242, 254, 0.08);
    padding-left: 1.8rem;
  }

  .nav-mobile-link:hover::before {
    opacity: 1;
  }

  .nav-mobile-link:hover::after {
    opacity: 1;
    animation: scan-line 0.6s ease-in-out;
  }

  @keyframes scan-line {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }

  .nav-mobile-link--active {
    color: #00f2fe;
    background: linear-gradient(90deg, rgba(0, 242, 254, 0.15) 0%, rgba(0, 242, 254, 0.05) 100%);
    border-left-color: #00f2fe;
    border-right-color: #00f2fe;
    box-shadow:
      inset -12px 0 20px rgba(0, 242, 254, 0.08),
      inset 3px 0 0 #00f2fe,
      0 0 20px rgba(0, 242, 254, 0.2);
    font-weight: 700;
    padding-left: 1.8rem;
    animation: active-pulse 2.5s ease-in-out infinite;
  }

  @keyframes active-pulse {
    0%, 100% {
      box-shadow:
        inset -12px 0 20px rgba(0, 242, 254, 0.08),
        inset 3px 0 0 #00f2fe,
        0 0 20px rgba(0, 242, 254, 0.2);
      background: linear-gradient(90deg, rgba(0, 242, 254, 0.15) 0%, rgba(0, 242, 254, 0.05) 100%);
    }
    50% {
      box-shadow:
        inset -12px 0 20px rgba(0, 242, 254, 0.12),
        inset 3px 0 0 #00f2fe,
        0 0 30px rgba(0, 242, 254, 0.4);
      background: linear-gradient(90deg, rgba(0, 242, 254, 0.2) 0%, rgba(0, 242, 254, 0.08) 100%);
    }
  }

  .nav-mobile-link--active::before {
    opacity: 1;
  }

  .nav-mobile-link--active::after {
    opacity: 1;
    animation: scan-line-active 1.5s ease-in-out infinite;
  }

  @keyframes scan-line-active {
    0%, 100% {
      transform: translateX(-100%);
      opacity: 0.5;
    }
    50% {
      transform: translateX(100%);
      opacity: 1;
    }
  }

  .nav-mobile-num {
    font-size: 0.65rem;
    color: rgba(0, 242, 254, 0.45);
    font-weight: 600;
    letter-spacing: 0.08em;
    min-width: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 242, 254, 0.05);
    border: 1px solid rgba(0, 242, 254, 0.2);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-mobile-link:hover .nav-mobile-num {
    background: rgba(0, 242, 254, 0.1);
    border-color: rgba(0, 242, 254, 0.4);
    color: rgba(0, 242, 254, 0.7);
  }

  .nav-mobile-link--active .nav-mobile-num {
    color: #00f2fe;
    text-shadow: 0 0 12px rgba(0, 242, 254, 0.8);
    background: rgba(0, 242, 254, 0.2);
    border-color: #00f2fe;
    box-shadow: 0 0 12px rgba(0, 242, 254, 0.5);
  }

  .nav-mobile-text {
    flex: 1;
  }

  .nav-mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
    color: #020811;
    border: none;
    padding: 0.9rem 1.5rem;
    border-radius: 8px;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    width: 100%;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(0, 242, 254, 0.3);
  }

  .nav-mobile-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .nav-mobile-cta:hover {
    transform: translateY(-3px);
    box-shadow:
      0 8px 32px rgba(0, 242, 254, 0.5),
      0 0 20px rgba(79, 172, 254, 0.4);
  }

  .nav-mobile-cta:hover::before {
    opacity: 1;
  }

  .nav-mobile-cta:active {
    transform: translateY(-1px);
  }

  .nav-mobile-cta svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ── Responsive show/hide ── */
  @media (max-width: 900px) {
    .nav-links          { display: none; }
    .nav-section-badge  { display: none !important; }
    .nav-cta            { display: none; }
    .nav-hamburger      { display: flex; }
  }

  @media (max-width: 480px) {
    .nav-inner { padding: 1rem; }
    .nav-brand-sub { display: none; }
  }

  @media (hover: none), (pointer: coarse) {
    .nav-mobile-menu {
      overscroll-behavior: contain;
    }

    .nav-mobile-links {
      -webkit-overflow-scrolling: touch;
    }

    .nav-brand:hover .nav-logo-img {
      filter: drop-shadow(0 0 8px rgba(0,242,254,0.45));
    }

    .nav-link:hover {
      color: #64748b;
      background: transparent;
    }

    .nav-link:hover::after {
      transform: translateX(-50%) scaleX(0);
    }

    .nav-link.is-active:hover {
      color: #00f2fe;
    }

    .nav-link.is-active:hover::after,
    .nav-link.is-active::after {
      transform: translateX(-50%) scaleX(1);
    }

    .nav-cta:hover {
      transform: none;
      box-shadow: none;
    }

    .nav-hamburger:hover {
      background: rgba(255,255,255,0.05);
    }

    .nav-mobile-close:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.1);
      color: #f0f6ff;
    }

    .nav-mobile-link:hover {
      color: #64748b;
      border-left-color: transparent;
      background: transparent;
    }

    .nav-mobile-link:hover::before {
      opacity: 0;
    }

    .nav-mobile-link--active:hover {
      color: #00f2fe;
      background: rgba(0, 242, 254, 0.12);
      border-left-color: #00f2fe;
    }

    .nav-mobile-link--active:hover::before {
      opacity: 1;
    }

    .nav-mobile-cta:hover {
      transform: none;
      box-shadow: none;
    }

    .nav-mobile-cta:hover::before {
      opacity: 0;
    }

    .nav-cta,
    .nav-hamburger,
    .nav-mobile-close,
    .nav-mobile-link,
    .nav-mobile-cta {
      touch-action: manipulation;
    }

    .nav-cta:active,
    .nav-hamburger:active,
    .nav-mobile-close:active,
    .nav-mobile-link:active,
    .nav-mobile-cta:active {
      opacity: 0.86;
    }
  }
</style>

<script>
  const navRoot      = document.getElementById('site-nav-container') as HTMLElement;
  const hamburger    = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileMenu   = document.getElementById('mobile-menu') as HTMLElement;
  const mobileClose  = document.getElementById('mobile-close') as HTMLButtonElement;
  const navLinks     = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const mobileLinks  = document.querySelectorAll<HTMLAnchorElement>('.nav-mobile-link');
  const sectionLabel = document.getElementById('nav-section-label') as HTMLElement;

  /* ── Scroll-aware sticky ── */
  const handleScroll = () => {
    if (window.scrollY > 60) {
      navRoot.classList.add('scrolled');
    } else {
      navRoot.classList.remove('scrolled');
    }

    /* Active section highlight */
    const sections = ['home','about','prizes','timeline','rules','submission','organizers','contact'];
    let current = 'home';
    for (const id of sections.slice().reverse()) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= 120) {
        current = id;
        break;
      }
    }
    navLinks.forEach(a => {
      a.classList.toggle('is-active', a.getAttribute('href') === `#${current}`);
    });

    // No highlighting for mobile links

    if (sectionLabel) {
      sectionLabel.textContent = current.charAt(0).toUpperCase() + current.slice(1);
    }
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });

  /* ── Close menu function ── */
  const closeMenu = () => {
    hamburger?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    mobileMenu?.classList.remove('is-open');
    mobileMenu?.setAttribute('aria-hidden', 'true');
  };

  /* ── Hamburger toggle ── */
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.classList.toggle('is-open', isOpen);
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  /* ── Close menu on close button click ── */
  mobileClose?.addEventListener('click', closeMenu);

  /* ── Close menu when clicking on background ── */
  mobileMenu?.addEventListener('click', (e) => {
    if (e.target === mobileMenu) closeMenu();
  });

  /* ── Close menu on link click ── */
  document.querySelectorAll('[data-close-menu]').forEach(el => {
    el.addEventListener('click', closeMenu);
  });
</script>
