---
import logoImg from "../assets/images/logo-high.png";
---

<header class="nav-root" id="site-nav-container">
  <nav class="nav-inner" id="site-nav" role="navigation" aria-label="Main navigation">

    <!-- Logo -->
    <a href="#home" class="nav-brand" aria-label="CodeCraft – back to top" id="nav-brand-link">
      <img src={logoImg.src} alt="CodeCraft logo" class="nav-logo-img" />
      <div class="nav-brand-text">
        <span class="nav-brand-name">CODE<span class="nav-brand-accent">CRAFT</span></span>
        <span class="nav-brand-sub">IIE Tech Club</span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <nav class="nav-links" aria-label="Sections" id="nav-links-desktop">
      <a href="#about"      class="nav-link" id="nl-about">About</a>
      <a href="#prizes"     class="nav-link" id="nl-prizes">Prizes</a>
      <a href="#timeline"   class="nav-link" id="nl-timeline">Timeline</a>
      <a href="#rules"      class="nav-link" id="nl-rules">Rules</a>
      <a href="#submission" class="nav-link" id="nl-submit">Submit</a>
      <a href="#organizers" class="nav-link" id="nl-team">Team</a>
    </nav>

    <!-- Right side -->
    <div class="nav-right">
      <!-- Active section badge -->
      <span class="nav-section-badge" id="nav-section-badge" aria-live="polite" aria-atomic="true">
        <span class="nav-section-dot" aria-hidden="true"></span>
        <span id="nav-section-label">Home</span>
      </span>

      <!-- Register CTA -->
      <button class="nav-cta" type="button" data-auth-trigger id="nav-register-btn">
        <span>Register</span>
        <svg viewBox="0 0 16 16" fill="none" class="nav-cta-icon" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Hamburger (mobile) -->
      <button class="nav-hamburger" id="hamburger" aria-label="Toggle menu" aria-controls="mobile-menu" aria-expanded="false" type="button">
        <span class="ham-line" id="hl-1"></span>
        <span class="ham-line" id="hl-2"></span>
        <span class="ham-line" id="hl-3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown menu -->
  <div class="nav-mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="nav-mobile-links" aria-label="Mobile navigation">
      <a href="#about"      class="nav-mobile-link" data-close-menu id="ml-about">
        <span class="nav-mobile-num">01</span> About
      </a>
      <a href="#prizes"     class="nav-mobile-link" data-close-menu id="ml-prizes">
        <span class="nav-mobile-num">02</span> Prizes
      </a>
      <a href="#timeline"   class="nav-mobile-link" data-close-menu id="ml-timeline">
        <span class="nav-mobile-num">03</span> Timeline
      </a>
      <a href="#rules"      class="nav-mobile-link" data-close-menu id="ml-rules">
        <span class="nav-mobile-num">04</span> Rules
      </a>
      <a href="#submission" class="nav-mobile-link" data-close-menu id="ml-submit">
        <span class="nav-mobile-num">05</span> Submission
      </a>
      <a href="#organizers" class="nav-mobile-link" data-close-menu id="ml-team">
        <span class="nav-mobile-num">06</span> Team
      </a>
      <a href="#contact"    class="nav-mobile-link" data-close-menu id="ml-contact">
        <span class="nav-mobile-num">07</span> Contact
      </a>
      <button class="nav-mobile-cta" type="button" data-auth-trigger data-close-menu id="ml-register">
        Register Now →
      </button>
    </nav>
  </div>
</header>

<style>
  /* ── Root ── */
  .nav-root {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: padding 0.5s cubic-bezier(0.16,1,0.3,1);
    padding: 0;
  }

  /* ── Inner pill ── */
  .nav-inner {
    width: 100%;
    max-width: 1280px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    transition:
      padding 0.5s cubic-bezier(0.16,1,0.3,1),
      background 0.5s ease,
      border-radius 0.5s ease,
      border-color 0.5s ease,
      box-shadow 0.5s ease,
      max-width 0.5s ease;
    border: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    backdrop-filter: none;
  }

  /* scrolled state (toggled via JS) */
  .nav-root.scrolled {
    padding: 0.75rem 1rem;
  }

  .nav-root.scrolled .nav-inner {
    padding: 0.75rem 1.5rem;
    max-width: 1080px;
    background: rgba(3, 8, 18, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 999px;
    border-color: rgba(0, 242, 254, 0.15);
    box-shadow:
      0 0 0 1px rgba(0,242,254,0.06) inset,
      0 20px 60px rgba(0,0,0,0.5),
      0 0 30px rgba(0,242,254,0.06);
  }

  /* ── Brand ── */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(0,242,254,0.45));
    transition: filter 0.3s ease;
  }

  .nav-brand:hover .nav-logo-img {
    filter: drop-shadow(0 0 16px rgba(0,242,254,0.7));
  }

  .nav-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .nav-brand-name {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1.05rem;
    color: #f0f6ff;
    letter-spacing: 0.04em;
  }

  .nav-brand-accent {
    color: #00f2fe;
  }

  .nav-brand-sub {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.5rem;
    color: rgba(100, 116, 139, 0.8);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 0.2rem;
  }

  /* ── Desktop links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #64748b;
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 16px;
    height: 1px;
    background: #00f2fe;
    border-radius: 999px;
    transition: transform 0.25s ease;
  }

  .nav-link:hover {
    color: #f0f6ff;
    background: rgba(255,255,255,0.04);
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .nav-link.is-active {
    color: #00f2fe;
  }

  /* ── Right side ── */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* Section badge */
  .nav-section-badge {
    display: none;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #64748b;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
  }

  .nav-root.scrolled .nav-section-badge {
    display: flex;
  }

  .nav-section-dot {
    width: 5px;
    height: 5px;
    background: #00f2fe;
    border-radius: 50%;
    box-shadow: 0 0 6px #00f2fe;
    animation: dot-pulse 2s infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  /* CTA button */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: linear-gradient(135deg, #00f2fe, #4facfe);
    color: #020811;
    border: none;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,242,254,0.35);
  }

  .nav-cta-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.55rem 0.65rem;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .nav-hamburger:hover {
    background: rgba(255,255,255,0.08);
  }

  .ham-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #f0f6ff;
    border-radius: 999px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* hamburger open state */
  .nav-hamburger.is-open #hl-1 { transform: translateY(6.5px) rotate(45deg); }
  .nav-hamburger.is-open #hl-2 { opacity: 0; transform: scaleX(0); }
  .nav-hamburger.is-open #hl-3 { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Mobile menu ── */
  .nav-mobile-menu {
    width: 100%;
    max-height: 0;
    overflow: hidden;
    background: rgba(3,8,18,0.97);
    border-bottom: 1px solid rgba(0,242,254,0.1);
    backdrop-filter: blur(16px);
    transition: max-height 0.45s cubic-bezier(0.16,1,0.3,1);
  }

  .nav-mobile-menu.is-open {
    max-height: 600px;
  }

  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 0.25rem;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #64748b;
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }

  .nav-mobile-link:hover {
    color: #00f2fe;
    background: rgba(0,242,254,0.05);
    border-color: rgba(0,242,254,0.12);
    transform: translateX(4px);
  }

  .nav-mobile-num {
    font-size: 0.55rem;
    color: rgba(0,242,254,0.35);
    font-weight: 400;
  }

  .nav-mobile-cta {
    margin-top: 1rem;
    background: linear-gradient(135deg, #00f2fe, #4facfe);
    color: #020811;
    border: none;
    padding: 0.85rem;
    border-radius: 8px;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    width: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-mobile-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,242,254,0.35);
  }

  /* ── Responsive show/hide ── */
  @media (max-width: 900px) {
    .nav-links          { display: none; }
    .nav-section-badge  { display: none !important; }
    .nav-cta            { display: none; }
    .nav-hamburger      { display: flex; }
  }

  @media (max-width: 480px) {
    .nav-inner { padding: 1rem; }
    .nav-brand-sub { display: none; }
  }
</style>

<script>
  const navRoot      = document.getElementById('site-nav-container') as HTMLElement;
  const hamburger    = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileMenu   = document.getElementById('mobile-menu') as HTMLElement;
  const navLinks     = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const sectionLabel = document.getElementById('nav-section-label') as HTMLElement;

  /* ── Scroll-aware sticky ── */
  const handleScroll = () => {
    if (window.scrollY > 60) {
      navRoot.classList.add('scrolled');
    } else {
      navRoot.classList.remove('scrolled');
    }

    /* Active section highlight */
    const sections = ['home','about','prizes','timeline','rules','submission','organizers','contact'];
    let current = 'home';
    for (const id of sections) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= 120) current = id;
    }
    navLinks.forEach(a => {
      a.classList.toggle('is-active', a.getAttribute('href') === `#${current}`);
    });
    if (sectionLabel) {
      sectionLabel.textContent = current.charAt(0).toUpperCase() + current.slice(1);
    }
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });

  /* ── Hamburger toggle ── */
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.classList.toggle('is-open', isOpen);
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  /* ── Close menu on link click ── */
  document.querySelectorAll('[data-close-menu]').forEach(el => {
    el.addEventListener('click', () => {
      hamburger?.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu?.classList.remove('is-open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
    });
  });
</script>
