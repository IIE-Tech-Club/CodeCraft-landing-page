---
import logoImg from "../assets/images/logo-high.png";
---

<footer class="cyber-footer" id="footer">
  <div class="cf-backdrop" aria-hidden="true"></div>

  <div class="cf-inner">
    
    <!-- BLOCK 1: SYSTEM IDENTIFICATION -->
    <div class="cf-block cf-sys-info">
      <a href="#home" class="cf-brand" aria-label="CodeCraft home">
        <img src={logoImg.src} width={logoImg.width} height={logoImg.height} alt="CodeCraft logo" class="cf-logo" loading="lazy" decoding="async" />
        <div class="cf-brand-text">
          <span class="cf-title">CODE<span class="cf-hl">CRAFT</span></span>
          <span class="cf-version">v2026.1 // SYS_ONLINE</span>
        </div>
      </a>
      <p class="cf-desc">
        > Initiating protocol...<br/>
        > Loading IIE Tech Club modules...<br/>
        > Bridge between physical circuits and digital logic established. 
      </p>
      <div class="cf-sys-metrics">
        <div class="metric"><span class="lbl">LOC:</span> IIE CAMPUS</div>
        <div class="metric"><span class="lbl">MEM:</span> 2-4 NODES/TEAM</div>
        <div class="metric"><span class="lbl">RWD:</span> 3500 CR</div>
      </div>
    </div>

    <!-- BLOCK 2: ROOT DIRECTORY -->
    <div class="cf-block cf-dir">
      <h3 class="cf-header"><span class="cf-slash">//</span> ROOT_DIRECTORY</h3>
      <nav class="cf-nav" aria-label="Footer navigation">
        <a href="#about" class="cf-link"><span class="cf-index">01</span> ABOUT_MODULE</a>
        <a href="#prizes" class="cf-link"><span class="cf-index">02</span> BOUNTY_BOARD</a>
        <a href="#timeline" class="cf-link"><span class="cf-index">03</span> EXECUTION_PIPELINE</a>
        <a href="#rules" class="cf-link"><span class="cf-index">04</span> SYSTEM_PROTOCOLS</a>
        <a href="#submission" class="cf-link"><span class="cf-index">05</span> UPLOAD_PAYLOADS</a>
        <a href="#organizers" class="cf-link"><span class="cf-index">06</span> NETWORK_ADMINS</a>
      </nav>
    </div>

    <!-- BLOCK 3: UPLINK & TERMINAL -->
    <div class="cf-block cf-uplink">
      <h3 class="cf-header"><span class="cf-slash">//</span> ESTABLISH_LINK</h3>
      
      <div class="cf-socials">
        <a href="https://github.com" target="_blank" rel="noreferrer" aria-label="GitHub" class="cf-social-btn">
          <span></span><span></span><span></span><span></span>
          <svg viewBox="0 0 24 24"><path d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.2-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.8 1.2 1.8 1.2 1 .1 1.7-.2 2.1-.6.1-.7.4-1.1.7-1.3-2.5-.3-5.1-1.2-5.1-5.4 0-1.2.4-2.2 1.1-3-.1-.3-.5-1.5.1-3.1 0 0 .9-.3 3 .9a10.5 10.5 0 0 1 5.4 0c2.1-1.2 3-.9 3-.9.6 1.6.2 2.8.1 3.1.7.8 1.1 1.8 1.1 3 0 4.2-2.6 5.1-5.1 5.4.4.3.8 1 .8 2.1v3.1c0 .4.2.7.8.6A12 12 0 0 0 12 .5Z" fill="currentColor"/></svg>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noreferrer" aria-label="LinkedIn" class="cf-social-btn">
          <span></span><span></span><span></span><span></span>
          <svg viewBox="0 0 24 24"><path d="M4.98 3.5A2.48 2.48 0 1 1 0 3.48a2.48 2.48 0 0 1 4.98.02ZM.5 8.2h4.9V24H.5V8.2Zm8.1 0h4.7v2.1h.1c.7-1.2 2.5-2.5 5.2-2.5 5.5 0 6.5 3.6 6.5 8.2V24h-4.9v-7c0-1.7 0-3.9-2.3-3.9s-2.7 1.8-2.7 3.8V24H8.6V8.2Z" fill="currentColor"/></svg>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noreferrer" aria-label="Instagram" class="cf-social-btn">
          <span></span><span></span><span></span><span></span>
          <svg viewBox="0 0 24 24"><path d="M7 0h10a7 7 0 0 1 7 7v10a7 7 0 0 1-7 7H7a7 7 0 0 1-7-7V7a7 7 0 0 1 7-7Zm0 2.2A4.8 4.8 0 0 0 2.2 7v10A4.8 4.8 0 0 0 7 21.8h10a4.8 4.8 0 0 0 4.8-4.8V7A4.8 4.8 0 0 0 17 2.2H7Zm5 3.7a6.1 6.1 0 1 1 0 12.2 6.1 6.1 0 0 1 0-12.2Zm0 2.2a3.9 3.9 0 1 0 0 7.8 3.9 3.9 0 0 0 0-7.8Zm6.5-.8a1.4 1.4 0 1 1 0 2.8 1.4 1.4 0 0 1 0-2.8Z" fill="currentColor"/></svg>
        </a>
      </div>

      <div class="cf-terminal">
        <div class="cft-head">
          <div class="cft-dots"><i></i><i></i><i></i></div>
          <span>root@codecraft:~</span>
        </div>
        <div class="cft-body">
          <p>> status --check</p>
          <p class="cft-success">ALL_SYSTEMS_OPERATIONAL</p>
          <p>> await new_registration()</p>
          <p class="cft-blink">_</p>
        </div>
      </div>
    </div>
    
  </div>

  <div class="cf-bottom">
    <div class="cf-bottom-inner" aria-hidden="true">
      <div class="cf-status-bar">
        <span>SYS_LOG: <script is:inline>document.write(new Date().getFullYear())</script>.09.21</span>
        <span>COPYRIGHT_IIE_TECH_CLUB</span>
        <span>ALL_RIGHTS_RESERVED</span>
      </div>
      <div class="cf-tags">
        <span>[#CODECRAFT]</span>
        <span>[#HACKTHEFUTURE]</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .cyber-footer {
    position: relative;
    background: #020409;
    border-top: 2px solid rgba(0, 242, 254, 0.4);
    overflow: hidden;
    color: #e2e8f0;
    margin-top: 0;
  }

  /* Grid overlay */
  .cf-backdrop {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(0, 242, 254, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 242, 254, 0.05) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  .cf-backdrop::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 100%, rgba(0, 242, 254, 0.05) 0%, #020409 70%);
  }

  .cf-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
  }

  .cf-block {
    display: flex;
    flex-direction: column;
  }

  .cf-header {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: #fff;
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
  }
  .cf-slash { color: var(--c-cyan); }

  /* Brand Block */
  .cf-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .cf-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    filter: drop-shadow(0 0 10px rgba(0, 242, 254, 0.5));
  }

  .cf-brand-text {
    display: flex;
    flex-direction: column;
  }

  .cf-title {
    font-family: 'Orbitron', var(--font-mono);
    font-weight: 900;
    font-size: 1.5rem;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.05em;
  }
  .cf-hl { color: var(--c-cyan); }

  .cf-version {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(0, 242, 254, 0.6);
    letter-spacing: 0.15em;
    margin-top: 0.4rem;
  }

  .cf-desc {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #8b99af;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .cf-sys-metrics {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .cf-sys-metrics .metric {
    background: rgba(0, 242, 254, 0.05);
    border: 1px solid rgba(0, 242, 254, 0.2);
    padding: 0.3rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: #cbd5e1;
  }
  .cf-sys-metrics .lbl { color: var(--c-cyan); font-weight: bold; margin-right: 0.3rem; }

  /* Navigation Block */
  .cf-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cf-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #8b99af;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cf-index {
    color: rgba(0, 242, 254, 0.3);
    font-size: 0.7rem;
    transition: color 0.3s ease;
  }

  .cf-link:hover {
    color: #fff;
    transform: translateX(5px);
    text-shadow: 0 0 10px rgba(0, 242, 254, 0.5);
  }
  .cf-link:hover .cf-index { color: var(--c-cyan); }

  /* Socials & Terminal */
  .cf-socials {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .cf-social-btn {
    position: relative;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    background: rgba(3, 7, 18, 0.8);
    color: #94a3b8;
    transition: all 0.3s ease;
  }

  .cf-social-btn span { position: absolute; width: 6px; height: 6px; border: 1px solid rgba(255,255,255,0.2); transition: all 0.3s ease; }
  .cf-social-btn span:nth-child(1) { top: 0; left: 0; border-right: none; border-bottom: none; }
  .cf-social-btn span:nth-child(2) { top: 0; right: 0; border-left: none; border-bottom: none; }
  .cf-social-btn span:nth-child(3) { bottom: 0; left: 0; border-right: none; border-top: none; }
  .cf-social-btn span:nth-child(4) { bottom: 0; right: 0; border-left: none; border-top: none; }

  .cf-social-btn svg { width: 18px; height: 18px; }

  .cf-social-btn:hover {
    color: var(--c-cyan);
    background: rgba(0, 242, 254, 0.05);
  }

  .cf-social-btn:hover span {
    border-color: var(--c-cyan);
    width: 10px; height: 10px;
  }

  .cf-terminal {
    background: rgba(4, 10, 24, 0.9);
    border: 1px solid rgba(0, 242, 254, 0.2);
    border-radius: 4px;
    overflow: hidden;
    font-family: var(--font-mono);
  }

  .cft-head {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .cft-dots { display: flex; gap: 4px; }
  .cft-dots i { width: 8px; height: 8px; border-radius: 50%; }
  .cft-dots i:nth-child(1) { background: #ef4444; }
  .cft-dots i:nth-child(2) { background: #eab308; }
  .cft-dots i:nth-child(3) { background: #22c55e; }

  .cft-head span { font-size: 0.65rem; color: #64748b; }

  .cft-body {
    padding: 1rem;
    font-size: 0.7rem;
    color: #e2e8f0;
    line-height: 1.6;
  }

  .cft-body p { margin: 0 0 0.25rem 0; }
  .cft-success { color: #4ade80; text-shadow: 0 0 5px rgba(74, 222, 128, 0.4); padding-left: 1rem; margin-bottom: 0.5rem !important; }
  .cft-blink { display:inline-block; width:6px; height:10px; background:#fff; animation: blink 1s infinite alternate; }

  @keyframes blink { 0% { opacity: 1; } 100% { opacity: 0; } }

  /* Bottom Bar */
  .cf-bottom {
    position: relative;
    z-index: 1;
    background: rgba(0, 0, 0, 0.4);
    border-top: 1px solid rgba(0, 242, 254, 0.1);
  }

  .cf-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cf-status-bar {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: #64748b;
    letter-spacing: 0.1em;
  }

  .cf-tags {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: rgba(0, 242, 254, 0.5);
    letter-spacing: 0.1em;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .cf-inner {
      grid-template-columns: 1fr 1fr;
    }
    .cf-sys-info { grid-column: 1 / -1; }
  }

  @media (max-width: 768px) {
    .cf-inner { grid-template-columns: 1fr; gap: 2rem; }
    .cf-brand { flex-direction: column; align-items: flex-start; }
    .cf-bottom-inner { flex-direction: column; gap: 0.75rem; align-items: flex-start; }
    .cf-status-bar { flex-wrap: wrap; gap: 0.5rem 1rem; }
  }

  @media (hover: none), (pointer: coarse) {
    .cf-link:hover {
      color: #8b99af;
      transform: none;
      text-shadow: none;
    }

    .cf-link:hover .cf-index {
      color: rgba(0, 242, 254, 0.3);
    }

    .cf-social-btn:hover {
      color: #94a3b8;
      background: rgba(3, 7, 18, 0.8);
    }

    .cf-social-btn:hover span {
      border-color: rgba(255,255,255,0.2);
      width: 6px;
      height: 6px;
    }

    .cf-link,
    .cf-social-btn {
      touch-action: manipulation;
    }

    .cf-link:active,
    .cf-social-btn:active {
      opacity: 0.86;
    }
  }
</style>
