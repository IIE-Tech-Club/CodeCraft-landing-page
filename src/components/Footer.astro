---
import logoImg from "../assets/images/logo-high.png";
---

<footer class="footer-root" id="footer">
  <!-- Scanline overlay -->
  <div class="footer-scanline" aria-hidden="true"></div>

  <!-- Top glow line -->
  <div class="footer-glow-line" aria-hidden="true"></div>

  <div class="footer-inner">
    <!-- Brand block -->
    <div class="footer-brand">
      <a href="#home" class="footer-logo-link" aria-label="CodeCraft home">
        <img src={logoImg.src} alt="CodeCraft Logo" class="footer-logo-img" />
        <div class="footer-brand-text">
          <span class="footer-brand-name">CODE<span class="footer-brand-accent">CRAFT</span></span>
          <span class="footer-brand-tagline">Where Software Meets Hardware</span>
        </div>
      </a>
      <p class="footer-brand-desc">
        An IIE Tech Club initiative — training the next generation of builders who merge code and circuits.
      </p>
      <!-- Social links -->
      <div class="footer-socials">
        <a href="https://github.com" target="_blank" rel="noreferrer" aria-label="GitHub" class="footer-social-btn">
          <svg viewBox="0 0 24 24" class="footer-social-icon"><path d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.2-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.8 1.2 1.8 1.2 1 .1 1.7-.2 2.1-.6.1-.7.4-1.1.7-1.3-2.5-.3-5.1-1.2-5.1-5.4 0-1.2.4-2.2 1.1-3-.1-.3-.5-1.5.1-3.1 0 0 .9-.3 3 .9a10.5 10.5 0 0 1 5.4 0c2.1-1.2 3-.9 3-.9.6 1.6.2 2.8.1 3.1.7.8 1.1 1.8 1.1 3 0 4.2-2.6 5.1-5.1 5.4.4.3.8 1 .8 2.1v3.1c0 .4.2.7.8.6A12 12 0 0 0 12 .5Z" fill="currentColor"/></svg>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noreferrer" aria-label="LinkedIn" class="footer-social-btn">
          <svg viewBox="0 0 24 24" class="footer-social-icon"><path d="M4.98 3.5A2.48 2.48 0 1 1 0 3.48a2.48 2.48 0 0 1 4.98.02ZM.5 8.2h4.9V24H.5V8.2Zm8.1 0h4.7v2.1h.1c.7-1.2 2.5-2.5 5.2-2.5 5.5 0 6.5 3.6 6.5 8.2V24h-4.9v-7c0-1.7 0-3.9-2.3-3.9s-2.7 1.8-2.7 3.8V24H8.6V8.2Z" fill="currentColor"/></svg>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noreferrer" aria-label="Instagram" class="footer-social-btn">
          <svg viewBox="0 0 24 24" class="footer-social-icon"><path d="M7 0h10a7 7 0 0 1 7 7v10a7 7 0 0 1-7 7H7a7 7 0 0 1-7-7V7a7 7 0 0 1 7-7Zm0 2.2A4.8 4.8 0 0 0 2.2 7v10A4.8 4.8 0 0 0 7 21.8h10a4.8 4.8 0 0 0 4.8-4.8V7A4.8 4.8 0 0 0 17 2.2H7Zm5 3.7a6.1 6.1 0 1 1 0 12.2 6.1 6.1 0 0 1 0-12.2Zm0 2.2a3.9 3.9 0 1 0 0 7.8 3.9 3.9 0 0 0 0-7.8Zm6.5-.8a1.4 1.4 0 1 1 0 2.8 1.4 1.4 0 0 1 0-2.8Z" fill="currentColor"/></svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="footer-col">
      <h4 class="footer-col-title">
        <span class="footer-col-title-bar"></span>
        Navigate
      </h4>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="#about" class="footer-link">
          <span class="footer-link-arrow">›</span> About
        </a>
        <a href="#prizes" class="footer-link">
          <span class="footer-link-arrow">›</span> Prizes
        </a>
        <a href="#timeline" class="footer-link">
          <span class="footer-link-arrow">›</span> Timeline
        </a>
        <a href="#rules" class="footer-link">
          <span class="footer-link-arrow">›</span> Rules
        </a>
        <a href="#submission" class="footer-link">
          <span class="footer-link-arrow">›</span> Submission
        </a>
        <a href="#organizers" class="footer-link">
          <span class="footer-link-arrow">›</span> Team
        </a>
        <a href="#contact" class="footer-link">
          <span class="footer-link-arrow">›</span> Contact
        </a>
      </nav>
    </div>

    <!-- Event Info -->
    <div class="footer-col">
      <h4 class="footer-col-title">
        <span class="footer-col-title-bar"></span>
        Event Info
      </h4>
      <ul class="footer-info-list">
        <li class="footer-info-item">
          <span class="footer-info-label">📅 Date</span>
          <span class="footer-info-value">21 September 2026</span>
        </li>
        <li class="footer-info-item">
          <span class="footer-info-label">🏫 Venue</span>
          <span class="footer-info-value">Ideal Institute of Engineering</span>
        </li>
        <li class="footer-info-item">
          <span class="footer-info-label">👥 Team Size</span>
          <span class="footer-info-value">2–4 Members</span>
        </li>
        <li class="footer-info-item">
          <span class="footer-info-label">🏆 Prize Pool</span>
          <span class="footer-info-value footer-info-highlight">₹3,500+</span>
        </li>
        <li class="footer-info-item">
          <span class="footer-info-label">📝 Registration</span>
          <span class="footer-info-value">Aug 20 – Sep 15</span>
        </li>
      </ul>
    </div>

    <!-- CTA -->
    <div class="footer-col footer-cta-col">
      <h4 class="footer-col-title">
        <span class="footer-col-title-bar footer-col-title-bar--orange"></span>
        Ready to Build?
      </h4>
      <p class="footer-cta-text">Spots are limited. Register now and secure your place at CODECRAFT 2026.</p>
      <button class="footer-cta-btn" type="button" data-auth-trigger>
        <span>Register Now</span>
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="footer-cta-icon">
          <path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="footer-status-pill">
        <span class="footer-status-dot"></span>
        Registration Open
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copyright">
        © 2026 CODECRAFT · Ideal Institute of Engineering · All rights reserved.
      </p>
      <div class="footer-bottom-tags">
        <span class="footer-tag">#HackTheFuture</span>
        <span class="footer-tag">#IIETechClub</span>
        <span class="footer-tag">#CODECRAFT2026</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-root {
    position: relative;
    background: #020409;
    border-top: 1px solid rgba(0, 242, 254, 0.12);
    overflow: hidden;
    margin-top: 0;
  }

  .footer-scanline {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 242, 254, 0.015) 2px,
      rgba(0, 242, 254, 0.015) 4px
    );
    pointer-events: none;
    z-index: 0;
  }

  .footer-glow-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 242, 254, 0.6), rgba(79, 172, 254, 0.4), transparent);
    pointer-events: none;
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 1fr 1fr;
    gap: 3rem;
    padding: 4rem 3rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Brand */
  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .footer-logo-img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    filter: drop-shadow(0 0 12px rgba(0, 242, 254, 0.5));
  }

  .footer-brand-text {
    display: flex;
    flex-direction: column;
  }

  .footer-brand-name {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1.3rem;
    color: #f8fafc;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .footer-brand-accent {
    color: #00f2fe;
  }

  .footer-brand-tagline {
    font-size: 0.7rem;
    color: #94a3b8;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
    font-family: 'Orbitron', sans-serif;
  }

  .footer-brand-desc {
    color: #64748b;
    font-size: 0.875rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 28ch;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer-social-btn {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #64748b;
    text-decoration: none;
    transition: all 0.25s ease;
    background: rgba(255, 255, 255, 0.03);
  }

  .footer-social-btn:hover {
    color: #00f2fe;
    border-color: rgba(0, 242, 254, 0.4);
    background: rgba(0, 242, 254, 0.06);
    transform: translateY(-2px);
    box-shadow: 0 0 15px rgba(0, 242, 254, 0.2);
  }

  .footer-social-icon {
    width: 18px;
    height: 18px;
  }

  /* Columns */
  .footer-col {}

  .footer-col-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #f8fafc;
    margin-bottom: 1.25rem;
  }

  .footer-col-title-bar {
    display: block;
    width: 18px;
    height: 2px;
    background: linear-gradient(90deg, #00f2fe, #4facfe);
    border-radius: 999px;
    flex-shrink: 0;
  }

  .footer-col-title-bar--orange {
    background: linear-gradient(90deg, #ff8c42, #fbbf24);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 0.2rem 0;
  }

  .footer-link:hover {
    color: #00f2fe;
    transform: translateX(4px);
  }

  .footer-link-arrow {
    color: rgba(0, 242, 254, 0.4);
    font-size: 1rem;
    line-height: 1;
    transition: color 0.2s ease;
  }

  .footer-link:hover .footer-link-arrow {
    color: #00f2fe;
  }

  /* Info list */
  .footer-info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-info-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .footer-info-label {
    font-size: 0.7rem;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer-info-value {
    font-size: 0.875rem;
    color: #94a3b8;
  }

  .footer-info-highlight {
    color: #fbbf24;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1rem;
  }

  /* CTA Column */
  .footer-cta-text {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, #00f2fe, #4facfe);
    color: #020409;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.25s ease;
    width: 100%;
    justify-content: center;
    margin-bottom: 1rem;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 0.05em;
  }

  .footer-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 242, 254, 0.35);
  }

  .footer-cta-icon {
    width: 16px;
    height: 16px;
  }

  .footer-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.2);
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    width: 100%;
    justify-content: center;
  }

  .footer-status-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 8px #4ade80;
    animation: footer-pulse 2s infinite;
  }

  @keyframes footer-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Bottom */
  .footer-bottom {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.25rem 3rem;
  }

  .footer-bottom-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: #334155;
    margin: 0;
  }

  .footer-bottom-tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-tag {
    font-size: 0.7rem;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 0.08em;
    color: #334155;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    transition: color 0.2s ease;
  }

  .footer-tag:hover {
    color: #00f2fe;
  }

  /* ── Responsive ── */

  /* Large tablet: 2-column grid, brand spans full width */
  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      padding: 3rem 2rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0 2rem;
      align-items: start;
    }
    .footer-logo-link { margin-bottom: 0; grid-row: 1; grid-column: 1; }
    .footer-brand-desc { grid-row: 1; grid-column: 2; margin-bottom: 0; max-width: none; }
    .footer-socials { grid-row: 1; grid-column: 3; }
  }

  /* Tablet: 1-column full width  */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 2.5rem 1.5rem;
    }

    /* Brand resets to stacked */
    .footer-brand {
      display: block;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-bottom: 1.75rem;
      margin-bottom: 1.75rem;
    }

    .footer-brand-desc { max-width: none; margin-bottom: 1rem; }

    /* Columns become accordion-like rows */
    .footer-col {
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding-bottom: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .footer-col:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    /* Quick links: 2-column grid  */
    .footer-links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 1rem;
    }

    .footer-link { padding: 0.4rem 0; font-size: 0.9rem; }

    /* Info list: 2-column grid */
    .footer-info-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.85rem 1rem;
    }

    /* CTA column: button full width (already set) */
    .footer-cta-btn { padding: 0.85rem; min-height: 52px; }

    /* Bottom bar */
    .footer-bottom { padding: 1.25rem 1.5rem; }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .footer-bottom-tags { flex-wrap: wrap; gap: 0.5rem; }
    .footer-copyright { font-size: 0.75rem; }
  }

  /* Mobile: ultra compact */
  @media (max-width: 480px) {
    .footer-inner { padding: 2rem 1.25rem; }

    .footer-brand-name { font-size: 1.1rem; }
    .footer-brand-tagline { font-size: 0.6rem; }
    .footer-brand-desc { font-size: 0.8rem; }

    .footer-logo-img { width: 42px; height: 42px; }

    .footer-links { grid-template-columns: 1fr; }
    .footer-info-list { grid-template-columns: 1fr; }

    .footer-col-title { font-size: 0.62rem; }

    .footer-social-btn { width: 42px; height: 42px; }

    .footer-bottom { padding: 1rem 1.25rem; }
    .footer-tag { font-size: 0.62rem; }
  }

  /* Touch: bigger tap targets */
  @media (hover: none) and (pointer: coarse) {
    .footer-link    { min-height: 44px; align-items: center; }
    .footer-cta-btn { min-height: 56px; }
    .footer-social-btn { min-height: 44px; min-width: 44px; }
  }

</style>
