---
interface Props {
  logoSrc: string;
}
const { logoSrc } = Astro.props;
---

<div class="loader-overlay" id="loader" aria-hidden="true">
  <!-- Animated Background -->
  <div class="loader-bg">
    <div class="loader-grid"></div>
    <div class="glow-orb glow-1"></div>
    <div class="glow-orb glow-2"></div>
    <div class="glow-orb glow-3"></div>
  </div>

  <div class="loader-content">
    <!-- Animated Logo -->
    <div class="logo-container">
      <div class="logo-frame">
        <img src={logoSrc} alt="CodeCraft" class="loader-logo" />
        <div class="logo-pulse"></div>
        <div class="logo-shine"></div>
      </div>
    </div>

    <!-- Code Building Section -->
    <div class="code-builder">
      <div class="code-window">
        <div class="code-header">
          <div class="code-dot red"></div>
          <div class="code-dot yellow"></div>
          <div class="code-dot green"></div>
          <span class="code-filename">hackathon.build.js</span>
        </div>
        <div class="code-content" id="code-display">
          <div class="code-line">
            <span class="code-keyword">const</span>
            <span class="code-var">project</span>
            <span class="code-op">=</span>
            <span class="code-string">"CodeCraft"</span>
            <span class="code-op">;</span>
          </div>
          <div class="code-line">
            <span class="code-keyword">let</span>
            <span class="code-var">teams</span>
            <span class="code-op">=</span>
            <span class="code-number" id="teams-count">0</span>
            <span class="code-op">;</span>
          </div>
          <div class="code-line">
            <span class="code-keyword">let</span>
            <span class="code-var">innovations</span>
            <span class="code-op">=</span>
            <span class="code-number" id="ideas-count">0</span>
            <span class="code-op">;</span>
          </div>
          <div class="code-line">
            <span class="code-keyword">const</span>
            <span class="code-var">status</span>
            <span class="code-op">=</span>
            <span class="code-string" id="status-text">"initializing"</span>
            <span class="code-op">;</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="loader-footer">
      <div class="progress-container">
        <div class="progress-bar">
          <div class="progress-fill" id="loader-progress"></div>
        </div>
        <div class="progress-meta">
          <span id="loader-percent">0%</span>
          <span class="pulse-text">Building hackathon experience...</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .loader-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: linear-gradient(135deg, #02040a 0%, #050812 50%, #0a0e1a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--c-cyan, #00f2fe);
    font-family: var(--font-body);
    overflow: hidden;
    transition: transform 1s cubic-bezier(0.8, 0, 0.2, 1), opacity 0.8s ease;
  }

  .loader-overlay.is-hidden {
    transform: translateY(-100%);
    pointer-events: none;
    opacity: 0;
  }

  /* Background Animation */
  .loader-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .loader-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 242, 254, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 242, 254, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    animation: float 8s ease-in-out infinite;
  }

  .glow-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0, 242, 254, 0.4), transparent);
    top: -100px;
    left: -100px;
    animation-delay: 0s;
  }

  .glow-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(79, 172, 254, 0.3), transparent);
    bottom: -150px;
    right: -150px;
    animation-delay: 2s;
  }

  .glow-3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(142, 45, 226, 0.2), transparent);
    top: 50%;
    right: 10%;
    animation-delay: 4s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(30px, -30px); }
    66% { transform: translate(-20px, 20px); }
  }

  /* Content Layout */
  .loader-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 800px;
    width: 90%;
  }

  /* Logo Container */
  .logo-container {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .logo-frame {
    position: relative;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loader-logo {
    width: 100px;
    height: 100px;
    object-fit: contain;
    filter: drop-shadow(0 0 20px rgba(0, 242, 254, 0.6));
    animation: logo-bounce 2s cubic-bezier(0.34, 1.56, 0.64, 1) infinite;
    position: relative;
    z-index: 2;
  }

  @keyframes logo-bounce {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.05); }
  }

  .logo-pulse {
    position: absolute;
    inset: -10px;
    border: 2px solid rgba(0, 242, 254, 0.3);
    border-radius: 50%;
    animation: pulse-ring 2s ease-out infinite;
  }

  .logo-shine {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(from 0deg, transparent, rgba(0, 242, 254, 0.3), transparent);
    animation: spin-shine 3s linear infinite;
  }

  @keyframes pulse-ring {
    0% {
      transform: scale(1);
      opacity: 1;
      border-color: rgba(0, 242, 254, 0.6);
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
      border-color: transparent;
    }
  }

  @keyframes spin-shine {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Code Builder Section */
  .code-builder {
    width: 100%;
    max-width: 600px;
  }

  .code-window {
    background: rgba(8, 14, 28, 0.8);
    border: 1px solid rgba(0, 242, 254, 0.25);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
  }

  .code-header {
    background: rgba(0, 242, 254, 0.08);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(0, 242, 254, 0.15);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .code-dot.red { background: #ff6b6b; }
  .code-dot.yellow { background: #ffd93d; }
  .code-dot.green { background: #6bcf7f; }

  .code-filename {
    margin-left: auto;
    font-size: 0.65rem;
    color: rgba(0, 242, 254, 0.7);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .code-content {
    padding: 1.25rem;
    font-family: var(--font-code);
    font-size: 0.8rem;
    color: rgba(226, 232, 240, 0.8);
    min-height: 120px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .code-line {
    opacity: 0;
    animation: code-type 0.4s ease-out forwards;
  }

  .code-line:nth-child(1) { animation-delay: 0.1s; }
  .code-line:nth-child(2) { animation-delay: 0.5s; }
  .code-line:nth-child(3) { animation-delay: 0.9s; }
  .code-line:nth-child(4) { animation-delay: 1.3s; }

  @keyframes code-type {
    0% {
      opacity: 0;
      transform: translateX(-10px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .code-keyword { color: #ff6b9d; font-weight: 600; }
  .code-var { color: #00f2fe; }
  .code-op { color: #4facfe; }
  .code-string { color: #6bcf7f; }
  .code-number {
    color: #ffd93d;
    animation: number-count 2s ease-out forwards;
  }

  @keyframes number-count {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Stats Container */
  .stats-container {
    display: flex;
    align-items: center;
    gap: 2rem;
    width: 100%;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(0, 242, 254, 0.05);
    border: 1px solid rgba(0, 242, 254, 0.15);
    border-radius: 8px;
    backdrop-filter: blur(8px);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.6rem;
    color: rgba(0, 242, 254, 0.6);
    letter-spacing: 0.1em;
    font-weight: 600;
    text-transform: uppercase;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #00f2fe;
    font-family: var(--font-mono);
    min-width: 2.5rem;
    text-align: center;
  }

  .stat-value.status-pulse {
    animation: status-glow 1.5s ease-in-out infinite;
  }

  @keyframes status-glow {
    0%, 100% {
      color: #00f2fe;
      text-shadow: 0 0 10px rgba(0, 242, 254, 0.5);
    }
    50% {
      color: #4facfe;
      text-shadow: 0 0 20px rgba(79, 172, 254, 0.6);
    }
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, transparent, rgba(0, 242, 254, 0.3), transparent);
  }

  /* Footer & Progress */
  .loader-footer {
    width: 100%;
    max-width: 600px;
    margin-top: auto;
  }

  .progress-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(0, 242, 254, 0.1);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(0, 242, 254, 0.2);
  }

  .progress-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, #00f2fe, #4facfe, #8e2de2);
    box-shadow: 0 0 20px rgba(0, 242, 254, 0.6);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 10px;
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: rgba(0, 242, 254, 0.6);
    letter-spacing: 0.05em;
  }

  .pulse-text {
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* Responsive */
  @media (max-width: 640px) {
    .loader-content {
      width: 95%;
      gap: 1.5rem;
    }

    .code-content {
      font-size: 0.65rem;
      padding: 1rem;
      min-height: 100px;
    }

    .stats-container {
      gap: 1rem;
      padding: 1rem;
    }

    .stat-value {
      font-size: 1.2rem;
    }

    .logo-frame {
      width: 90px;
      height: 90px;
    }

    .loader-logo {
      width: 75px;
      height: 75px;
    }
  }
</style>

<script>


  const loader = document.getElementById('loader');
  const progress = document.getElementById('loader-progress');
  const percent = document.getElementById('loader-percent');
  const teamsCount = document.getElementById('teams-count');
  const ideasCount = document.getElementById('ideas-count');
  const statusText = document.getElementById('status-text');
  const statTeams = document.getElementById('stat-teams');
  const statIdeas = document.getElementById('stat-ideas');
  // const statStatus = document.getElementById('stat-status');
  const originalBodyOverflow = document.body.style.overflow;
  const originalRootOverflow = document.documentElement.style.overflow;
  const originalScrollBehavior = document.documentElement.style.scrollBehavior;

  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'manual';
  }

  function forceTopScroll() {
    document.documentElement.style.scrollBehavior = 'auto';
    document.documentElement.scrollTop = 0;
    document.body.scrollTop = 0;
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
  }

  function clearInitialHashScroll() {
    if (!window.location.hash) return;
    history.replaceState(null, document.title, window.location.pathname + window.location.search);
  }

  clearInitialHashScroll();
  forceTopScroll();

  // Animate number counting
  function animateNumber(element: HTMLElement | null, target: number, duration: number) {
    if (!element) return;
    let current = 0;
    const increment = target / (duration / 16);
    const interval = setInterval(() => {
      current += increment;
      if (current >= target) {
        element.textContent = String(target);
        clearInterval(interval);
      } else {
        element.textContent = String(Math.floor(current));
      }
    }, 16);
  }

  // Hackathon stats
  const stats = {
    teams: 48,
    ideas: 120,
    phases: ['initializing', 'building', 'testing', 'deploying', 'live!']
  };

  let currentPhase = 0;

  // Update status text periodically
  const statusInterval = setInterval(() => {
    if (currentPhase < stats.phases.length) {
      const newStatus = stats.phases[currentPhase];
      if (statusText) {
        statusText.style.opacity = '0';
        setTimeout(() => {
          if (statusText) {
            statusText.textContent = `"${newStatus}"`;
            statusText.style.transition = 'opacity 0.3s ease';
            statusText.style.opacity = '1';
          }
        }, 300);
      }
      currentPhase++;
    }
  }, 1500);



  async function startLoader() {
    // Lock scroll at the top while the loader is visible.
    forceTopScroll();
    clearInitialHashScroll();
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';

    // Animate counters
    animateNumber(teamsCount, stats.teams, 1500);
    animateNumber(ideasCount, stats.ideas, 1500);
    animateNumber(statTeams, stats.teams, 1500);
    animateNumber(statIdeas, stats.ideas, 1500);

    // Progress animation
    let progress_value = 0;
    const progressInterval = setInterval(() => {
      progress_value += Math.random() * 25;
      if (progress_value >= 100) {
        progress_value = 100;
        clearInterval(progressInterval);
      }
      if (progress) progress.style.width = `${progress_value}%`;
      if (percent) percent.textContent = `${Math.floor(progress_value)}%`;
    }, 400);

    // Final animation
    setTimeout(() => {
      forceTopScroll();
      if (loader) loader.classList.add('is-hidden');
      document.body.style.overflow = originalBodyOverflow;
      document.documentElement.style.overflow = originalRootOverflow;
      document.documentElement.style.scrollBehavior = originalScrollBehavior;
      clearInterval(statusInterval);
    }, 3500);
  }

  // Start when page is ready
  if (document.readyState === 'complete') {
    startLoader();
  } else {
    window.addEventListener('load', startLoader);
  }
</script>
