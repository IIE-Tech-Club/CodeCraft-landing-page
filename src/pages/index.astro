---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Loader from "../components/Loader.astro";
import CustomCursor from "../components/CustomCursor.astro";
import logoImg from "../assets/images/logo-high.png";
import "../styles/global.css";
import registration from "../assets/svg/register-svgrepo-com.svg";
import collaction from "../assets/svg/collection-upload-svgrepo-com.svg";
import presentation from "../assets/svg/presentation-6-svgrepo-com.svg";
import reward from "../assets/svg/award-reward-svgrepo-com.svg";
import ayush from "../assets/people/Ayush.jpeg";

const timeline = [
  {
    title: "Registration Opens",
    date: "20 August",
    icon: registration,
    desc: "Sign up your team and claim your spot",
  },
  {
    title: "PPT Submission Starts",
    date: "10 September",
    icon: collaction,
    desc: "Submit your presentation slides",
  },
  {
    title: "Registration Closes",
    date: "15 September",
    icon: registration,
    desc: "Last chance to register your team",
  },
  {
    title: "PPT Submission Ends",
    date: "20 September",
    icon: collaction,
    desc: "Deadline for all submissions",
  },
  {
    title: "Project Presentation",
    date: "21 September",
    icon: presentation,
    desc: "Demo your project to the judges",
  },
  {
    title: "Award Ceremony",
    date: "25 September",
    icon: reward,
    desc: "Winners announced & prizes distributed",
  },
];

const timelineTones = ["cyan", "blue", "orange", "purple", "blue"];
const timelinePattern = [
  { row: 1, slot: 1 },
  { row: 1, slot: 2 },
  { row: 1, slot: 3 },
  { row: 2, slot: 3 },
  { row: 2, slot: 2 },
  { row: 2, slot: 1 },
];

const timelineStops = timeline.map((item, index) => {
  const mapped = timelinePattern[index] ?? {
    row: Math.floor(index / 3) + 1,
    slot: (index % 3) + 1,
  };
  return {
    ...item,
    ...mapped,
    tone: timelineTones[index % timelineTones.length],
  };
});

const timelineRowCount = Math.max(...timelineStops.map((s) => s.row), 1);
const laneVariants = [
  "timeline-lane-top",
  "timeline-lane-middle",
  "timeline-lane-bottom",
];

const timelineRows = Array.from({ length: timelineRowCount }, (_, i) => ({
  variant: laneVariants[i] ?? "timeline-lane-middle",
  isLast: i === timelineRowCount - 1,
  items: timelineStops
    .filter((s) => s.row === i + 1)
    .sort((a, b) => a.slot - b.slot),
}));

