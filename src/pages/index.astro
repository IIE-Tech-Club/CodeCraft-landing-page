---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Loader from "../components/Loader.astro";
import CustomCursor from "../components/CustomCursor.astro";
import logoImg from "../assets/images/logo-high.png";
import "../styles/global.css";
import registration from "../assets/svg/register-svgrepo-com.svg";
import collaction from "../assets/svg/collection-upload-svgrepo-com.svg";
import presentation from "../assets/svg/presentation-6-svgrepo-com.svg";
import reward from "../assets/svg/award-reward-svgrepo-com.svg";

const timeline = [
  { title: "Registration Opens",   date: "20 August",    icon: registration, desc: "Sign up your team and claim your spot" },
  { title: "PPT Submission Starts",date: "10 September", icon: collaction,   desc: "Submit your presentation slides" },
  { title: "Registration Closes",  date: "15 September", icon: registration, desc: "Last chance to register your team" },
  { title: "PPT Submission Ends",  date: "20 September", icon: collaction,   desc: "Deadline for all submissions" },
  { title: "Project Presentation", date: "21 September", icon: presentation, desc: "Demo your project to the judges" },
  { title: "Award Ceremony",       date: "25 September", icon: reward,       desc: "Winners announced & prizes distributed" },
];

const timelineTones = ["cyan", "blue", "orange", "purple", "blue"];
const timelinePattern = [
  { row: 1, slot: 1 }, { row: 1, slot: 2 }, { row: 1, slot: 3 },
  { row: 2, slot: 3 }, { row: 2, slot: 2 }, { row: 2, slot: 1 },
];

const timelineStops = timeline.map((item, index) => {
  const mapped = timelinePattern[index] ?? { row: Math.floor(index / 3) + 1, slot: (index % 3) + 1 };
  return { ...item, ...mapped, tone: timelineTones[index % timelineTones.length] };
});

const timelineRowCount = Math.max(...timelineStops.map((s) => s.row), 1);
const laneVariants = ["timeline-lane-top", "timeline-lane-middle", "timeline-lane-bottom"];

const timelineRows = Array.from({ length: timelineRowCount }, (_, i) => ({
  variant: laneVariants[i] ?? "timeline-lane-middle",
  isLast: i === timelineRowCount - 1,
  items: timelineStops.filter((s) => s.row === i + 1).sort((a, b) => a.slot - b.slot),
}));

const organizers = [
  { name: "Ayush Choudhary",  init: "AC", github: "https://github.com/ayushchoudhary",  linkedin: "https://www.linkedin.com/in/ayushchoudhary" },
  { name: "Rahidul Khan",     init: "RK", github: "https://github.com/rahidulkhan",     linkedin: "https://www.linkedin.com/in/rahidulkhan" },
  { name: "Nilotpal Das",     init: "ND", github: "https://github.com/nilotpaldas",     linkedin: "https://www.linkedin.com/in/nilotpal-das" },
  { name: "Ronit Banerjee",   init: "RB", github: "https://github.com/ronitbanerjee",   linkedin: "https://www.linkedin.com/in/ronitbanerjee" },
  { name: "Debankan Dutta",   init: "DD", github: "https://github.com/debankandutta",   linkedin: "https://www.linkedin.com/in/debankandutta" },
];

const prizes = [
  { place: "1st", amount: "₹2,000", emoji: "🥇", rank: 1 },
  { place: "2nd", amount: "₹1,000", emoji: "🥈", rank: 2 },
  { place: "3rd", amount: "₹500",   emoji: "🥉", rank: 3 },
];

const rules = [
  { text: "Team size: 2–4 members from any year (1st–4th)", icon: "👥" },
  { text: "All team members must be from the college",       icon: "🏫" },
  { text: "Teams must submit PPT before the deadline",       icon: "📅" },
  { text: "Hardware integration is mandatory, not optional", icon: "⚙️" },
  { text: "Plagiarism of code or ideas will lead to DQ",    icon: "🚫" },
  { text: "Teams can use open-source libraries & frameworks",icon: "📦" },
  { text: "Final project must be demonstrated live",         icon: "🎥" },
];

const submissionRequirements = [
  { title: "PPT Submission",      desc: "Mandatory presentation slides covering your project",  icon: "📊", tag: "Required", color: "orange" },
  { title: "GitHub Repository",   desc: "Optional: share your open source code repository",     icon: "💻", tag: "Optional", color: "blue" },
  { title: "Software Demo",       desc: "Optional: a working demo of your software component",  icon: "⚙️", tag: "Optional", color: "blue" },
  { title: "Hardware Demo Video", desc: "Optional: showcase your hardware integration on video", icon: "🎥", tag: "Optional", color: "blue" },
];

const features = [
  { icon: "💡", num: "01", title: "Innovation First",  desc: "Build solutions combining software intelligence with hardware creativity." },
  { icon: "⚙️", num: "02", title: "Integration Focus", desc: "Master embedded systems, IoT, and web platforms in one cohesive prototype." },
  { icon: "🚀", num: "03", title: "Real Impact",        desc: "Cross-year teams (1st–4th year) working on projects that matter." },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="CODECRAFT — Where Software Meets Hardware. The ultimate hackathon at Ideal Institute of Engineering where builders blend code, circuits, and creativity." />
    <title>CODECRAFT | Where Software Meets Hardware</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- ── Page shell ── -->
    <div class="page-shell" id="page-shell">

      <!-- Ambient background orbs -->
      <div aria-hidden="true" style="position:fixed;inset:0;pointer-events:none;z-index:0;">
        <div style="position:absolute;width:700px;height:700px;background:#4facfe;top:-100px;left:-200px;border-radius:50%;filter:blur(140px);opacity:0.06;"></div>
        <div style="position:absolute;width:700px;height:700px;background:#8e2de2;bottom:-100px;right:-150px;border-radius:50%;filter:blur(140px);opacity:0.06;"></div>
        <div style="position:absolute;width:500px;height:500px;background:#00f2fe;top:40%;left:55%;border-radius:50%;filter:blur(140px);opacity:0.04;transform:translate(-50%,-50%);"></div>
      </div>

      <CustomCursor />
      <Loader logoSrc={logoImg.src} />

      <Navbar />

      <main id="main-content">

        <!-- ══════════════════════════════════════════════ HERO ══ -->
        <section class="hero" id="home" aria-label="Hero">
          <div class="hero-grid-bg" aria-hidden="true"></div>

          <div class="wrap" style="position:relative;z-index:2;">
            <div class="hero-content">

              <!-- Left text column -->
              <div class="hero-text">
                <div class="hero-eyebrow">
                  <span class="eyebrow-dot" aria-hidden="true"></span>
                  IIE Tech Club · Ideal Institute of Engineering
                </div>

                <h1 class="hero-heading">
                  <span class="hero-heading-code">CODE</span><span class="hero-heading-craft">CRAFT</span>
                </h1>

                <p class="hero-tagline">Where Software Meets Hardware</p>

                <p class="hero-desc">
                  <span style="color:var(--c-cyan);">// STATUS: ACTIVE</span><br/>
                  Bridge the gap between virtual logic and physical circuits. Join the ultimate hardware-first hackathon where raw code meets real engineering.
                </p>

                <!-- Countdown -->
                <div class="countdown" id="countdown" aria-label="Time until event">
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-days">--</span>
                    <span class="cd-lbl">Days</span>
                  </div>
                  <span class="cd-sep" aria-hidden="true">:</span>
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-hours">--</span>
                    <span class="cd-lbl">Hours</span>
                  </div>
                  <span class="cd-sep" aria-hidden="true">:</span>
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-mins">--</span>
                    <span class="cd-lbl">Mins</span>
                  </div>
                  <span class="cd-sep" aria-hidden="true">:</span>
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-secs">--</span>
                    <span class="cd-lbl">Secs</span>
                  </div>
                </div>

                <!-- CTAs -->
                <div class="hero-actions">
                  <button type="button" class="btn-primary" id="hero-register-btn" data-auth-trigger>
                    Register Now
                    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" style="width:16px;height:16px;">
                      <path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="btn-ghost" type="button" data-scroll-to="#about" id="hero-learn-btn">
                    Learn More ↓
                  </button>
                </div>
              </div>

              <!-- Right visual column -->
              <div class="hero-visual" aria-hidden="true">
                <div class="logo-stage">
                  <!-- HUD Tactical Brackets -->
                  <div class="hud-corner h-tl"></div>
                  <div class="hud-corner h-tr"></div>
                  <div class="hud-corner h-bl"></div>
                  <div class="hud-corner h-br"></div>
                  
                  <!-- HUD Data Readouts -->
                  <div class="hud-data d-left">SYS_v2.0.4</div>
                  <div class="hud-data d-right">LOC: 23.8°N</div>

                  <!-- Ambient Elements -->
                  <div class="logo-halo"></div>
                  <div class="logo-ring lr-1"></div>
                  <div class="logo-ring lr-2"></div>
                  <div class="logo-ring lr-3"></div>
                  <div class="logo-ring lr-4"></div>

                  <!-- Enhanced Orbits -->
                  <div class="orbit orbit-1">
                    <span class="orbit-node node-a">0x1A</span>
                  </div>
                  <div class="orbit orbit-2">
                    <span class="orbit-node node-b">CMD</span>
                  </div>
                  
                  <!-- Logo with Glitch Container -->
                  <div class="logo-container">
                    <img src={logoImg.src} alt="" class="logo-img" />
                    <div class="logo-scanner"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ── Stats bar ── -->
        <div class="stats-bar" role="region" aria-label="Event stats">
          <div class="wrap stats-bar-inner">
            <div class="stat-item">
              <span class="stat-value" data-counter="3500" data-suffix="₹">₹3500</span>
              <span class="stat-label">Prize Pool</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value" data-counter="4" data-suffix="">4</span>
              <span class="stat-label">Max Team Size</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value" data-counter="26" data-suffix=" Days">26 Days</span>
              <span class="stat-label">Event Duration</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Live Demo Required</span>
            </div>
          </div>
        </div>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ ABOUT ══ -->
        <section class="section" id="about" aria-labelledby="about-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">What is CODECRAFT?</p>
              <h2 class="section-title" id="about-title">Build. Integrate. Innovate.</h2>
              <p class="section-sub">A hackathon where software meets hardware — teams build real, working projects that blend code with circuits.</p>
            </div>

            <div class="feature-grid reveal-stagger">
              {features.map((f, i) => (
                <div class="fcard" data-index={i + 1}>
                  <span class="fcard-num">MODULE_{f.num}</span>
                  <span class="fcard-icon">{f.icon}</span>
                  <h3>{f.title}</h3>
                  <p>{f.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ PRIZES ══ -->
        <section class="section" id="prizes" aria-labelledby="prizes-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">Rewards</p>
              <h2 class="section-title" id="prizes-title">Prize Pool</h2>
              <p class="section-sub">Total Prize Pool: ₹3,500 + Certificates for all participants</p>
            </div>

            <div class="prizes-podium reveal">
              {prizes.map((p) => (
                <div class={`podium-card rank-${p.rank}`} data-rank={p.rank}>
                  <div class="podium-bar" aria-hidden="true"></div>
                  <div class="podium-medal">{p.emoji}</div>
                  <div class="podium-place">{p.place} Place</div>
                  <div class="podium-amount">{p.amount}</div>
                </div>
              ))}
            </div>

            <p class="reveal" style="text-align:center;color:var(--c-muted);font-size:0.9rem;margin-top:2rem;">
              🏆 All participants receive digital certificates of participation
            </p>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ TIMELINE ══ -->
        <section class="section" id="timeline" aria-labelledby="timeline-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">Schedule</p>
              <h2 class="section-title" id="timeline-title">Event Timeline</h2>
              <p class="section-sub">Key dates to keep in your calendar</p>
            </div>

            <div class="timeline-road reveal">
              {timelineRows.map((row) => (
                <div class={`timeline-lane ${row.variant} ${row.isLast ? 'timeline-lane-last' : 'timeline-lane-continues'}`}>
                  {row.items.map((item) => {
                    const iconValue = item.icon;
                    const isStringIcon = typeof iconValue === "string";
                    const isEmojiIcon = isStringIcon && [...iconValue].length <= 3;
                    const IconComponent = item.icon;
                    return (
                      <article class={`timeline-stop tone-${item.tone}`} style={`--slot: ${item.slot};`}>
                        <span class="timeline-node">
                          <span class="timeline-emoji">
                            {isEmojiIcon
                              ? iconValue
                              : isStringIcon
                                ? <img src={iconValue} alt="" loading="lazy" />
                                : <IconComponent />}
                          </span>
                        </span>
                        <div class="timeline-copy">
                          <h3>{item.title}</h3>
                          <p class="timeline-date">{item.date}</p>
                          <p class="timeline-desc">{item.desc}</p>
                        </div>
                      </article>
                    );
                  })}
                </div>
              ))}
            </div>

            <!-- Mobile vertical timeline (shown only below 768px) -->
            <div class="timeline-mobile reveal">
              {timelineStops.map((item) => {
                const iconValue = item.icon;
                const isStringIcon = typeof iconValue === "string";
                const isEmojiIcon = isStringIcon && [...iconValue].length <= 3;
                const IconComponent = item.icon;
                return (
                  <div class="tl-stop">
                    <div class={`tl-node tone-${item.tone}`}>
                      {isEmojiIcon
                        ? <span style="font-size:0.9rem;">{iconValue}</span>
                        : isStringIcon
                          ? <img src={iconValue} alt="" loading="lazy" />
                          : <IconComponent />}
                    </div>
                    <div class="tl-content">
                      <h3 class="tl-title">{item.title}</h3>
                      <p class="tl-date">{item.date}</p>
                      <p class="tl-desc">{item.desc}</p>
                    </div>
                  </div>
                );
              })}
            </div>

          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ RULES ══ -->
        <section class="section" id="rules" aria-labelledby="rules-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">Guidelines</p>
              <h2 class="section-title" id="rules-title">Participation Rules</h2>
              <p class="section-sub">Read carefully before registering</p>
            </div>

            <div class="rules-grid reveal-stagger">
              {rules.map((rule, idx) => (
                <div class="rule-card">
                  <span class="rule-num">{String(idx + 1).padStart(2, "0")}</span>
                  <span class="rule-icon">{rule.icon}</span>
                  <p class="rule-text">{rule.text}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ SUBMISSION ══ -->
        <section class="section" id="submission" aria-labelledby="submission-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">Deliverables</p>
              <h2 class="section-title" id="submission-title">Submission Requirements</h2>
              <p class="section-sub">Submit between 10–20 September. Include all mandatory materials.</p>
            </div>

            <div class="sub-grid reveal-stagger">
              {submissionRequirements.map((req) => (
                <div class={`sub-card sc-${req.color}`}>
                  <span class="sub-icon">{req.icon}</span>
                  <span class={`sub-tag tag-${req.tag.toLowerCase()}`}>{req.tag}</span>
                  <h3>{req.title}</h3>
                  <p>{req.desc}</p>
                </div>
              ))}
            </div>

            <div class="sub-tips reveal">
              <div class="tip-block">
                <h3>📝 PPT Format</h3>
                <ul>
                  <li>Maximum 15 slides</li>
                  <li>Include problem statement &amp; solution</li>
                  <li>Add team member details</li>
                  <li>Showcase hardware-software integration</li>
                </ul>
              </div>
              <div class="tip-block">
                <h3>💡 Pro Tips</h3>
                <ul>
                  <li>Clearly explain your innovation</li>
                  <li>Include diagrams and flowcharts</li>
                  <li>Mention technologies used</li>
                  <li>Highlight real-world applications</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ ORGANIZERS ══ -->
        <section class="section" id="organizers" aria-labelledby="organizers-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">The Team</p>
              <h2 class="section-title" id="organizers-title">Meet the Organizers</h2>
              <p class="section-sub">Passionate people bringing CODECRAFT to life</p>
            </div>

            <div class="org-grid reveal-stagger">
              {organizers.map((org, i) => (
                <div class="org-card" style={`--i: ${i}`}>
                  <div class="org-av">{org.init}</div>
                  <p class="org-name">{org.name}</p>
                  <p class="org-role">Organizer</p>
                  <div class="org-socials">
                    <a href={org.github} target="_blank" rel="noreferrer" aria-label={`${org.name} GitHub`} class="org-social">
                      <svg viewBox="0 0 24 24"><path d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.2-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.8 1.2 1.8 1.2 1 .1 1.7-.2 2.1-.6.1-.7.4-1.1.7-1.3-2.5-.3-5.1-1.2-5.1-5.4 0-1.2.4-2.2 1.1-3-.1-.3-.5-1.5.1-3.1 0 0 .9-.3 3 .9a10.5 10.5 0 0 1 5.4 0c2.1-1.2 3-.9 3-.9.6 1.6.2 2.8.1 3.1.7.8 1.1 1.8 1.1 3 0 4.2-2.6 5.1-5.1 5.4.4.3.8 1 .8 2.1v3.1c0 .4.2.7.8.6A12 12 0 0 0 12 .5Z" fill="currentColor"/></svg>
                    </a>
                    <a href={org.linkedin} target="_blank" rel="noreferrer" aria-label={`${org.name} LinkedIn`} class="org-social">
                      <svg viewBox="0 0 24 24"><path d="M4.98 3.5A2.48 2.48 0 1 1 0 3.48a2.48 2.48 0 0 1 4.98.02ZM.5 8.2h4.9V24H.5V8.2Zm8.1 0h4.7v2.1h.1c.7-1.2 2.5-2.5 5.2-2.5 5.5 0 6.5 3.6 6.5 8.2V24h-4.9v-7c0-1.7 0-3.9-2.3-3.9s-2.7 1.8-2.7 3.8V24H8.6V8.2Z" fill="currentColor"/></svg>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ CONTACT ══ -->
        <section class="section" id="contact" aria-labelledby="contact-title">
          <div class="wrap">
            <div class="contact-card reveal">
              <div class="contact-aurora contact-aurora-a" aria-hidden="true"></div>
              <div class="contact-aurora contact-aurora-b" aria-hidden="true"></div>

              <div class="contact-left">
                <p class="contact-kicker">Get in touch</p>
                <h2 class="contact-title" id="contact-title">Need Help?</h2>
                <p class="contact-sub">Reach out to our coordinators directly — we're here to guide you.</p>
                <div class="contact-chips" aria-label="Support highlights">
                  <span class="contact-chip">Fast response</span>
                  <span class="contact-chip">Student coordinators</span>
                  <span class="contact-chip">Tap to call</span>
                </div>
              </div>

              <div class="contact-right">
                <a href="tel:+918473868464" class="contact-link" aria-label="Call Ayush Choudhary">
                  <span class="contact-link-icon">📞</span>
                  <div style="display:flex;flex-direction:column;gap:0.15rem;">
                    <span style="font-size:1.1rem;font-weight:600;color:white;">Ayush Choudhary</span>
                    <span class="contact-link-text">+91 8473 868 464</span>
                  </div>
                  <span class="contact-link-action">Call</span>
                </a>
                <a href="tel:+919832577462" class="contact-link" aria-label="Call Rahidul Khan">
                  <span class="contact-link-icon">📞</span>
                  <div style="display:flex;flex-direction:column;gap:0.15rem;">
                    <span style="font-size:1.1rem;font-weight:600;color:white;">Rahidul Khan</span>
                    <span class="contact-link-text">+91 9832 577 462</span>
                  </div>
                  <span class="contact-link-action">Call</span>
                </a>
                <a href="tel:+919382770196" class="contact-link" aria-label="Call Debankan Dutta">
                  <span class="contact-link-icon">📞</span>
                  <div style="display:flex;flex-direction:column;gap:0.15rem;">
                    <span style="font-size:1.1rem;font-weight:600;color:white;">Debankan Dutta</span>
                    <span class="contact-link-text">+91 9382 770 196</span>
                  </div>
                  <span class="contact-link-action">Call</span>
                </a>
                <a href="tel:+919832577462" class="contact-link" aria-label="Call Nilotpal Das">
                  <span class="contact-link-icon">📞</span>
                  <div style="display:flex;flex-direction:column;gap:0.15rem;">
                    <span style="font-size:1.1rem;font-weight:600;color:white;">Nilotpal Das</span>
                    <span class="contact-link-text">+91 9832 577 462</span>
                  </div>
                  <span class="contact-link-action">Call</span>
                </a>
                <a href="tel:+918473868464" class="contact-link" aria-label="Call Ronit Banerjee">
                  <span class="contact-link-icon">📞</span>
                  <div style="display:flex;flex-direction:column;gap:0.15rem;">
