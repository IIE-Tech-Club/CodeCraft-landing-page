---
import Navbar from "../components/Navbar.astro";
import logoImg from "../assets/images/logo-high.png";
import "../styles/global.css";
import registration from "../assets/svg/register-svgrepo-com.svg";
import collaction from "../assets/svg/collection-upload-svgrepo-com.svg";
import presentation from "../assets/svg/presentation-6-svgrepo-com.svg";
import reward from "../assets/svg/award-reward-svgrepo-com.svg";

const timeline = [
  { title: "Registration Opens",   date: "20 August",        icon: registration, desc: "Sign up your team and claim your spot" },
  { title: "Registration Closes",  date: "15 September",     icon: registration, desc: "Last chance to register your team" },
  { title: "PPT Submission Starts",       date: "10 September",  icon: collaction, desc: "Submit your presentation slides" },
  { title: "PPT Submission Ends",       date: "20 September",  icon: collaction, desc: "Submit your presentation slides" },
  { title: "Project Presentation", date: "21 September",     icon: presentation, desc: "Demo your project to the judges" },
  { title: "Award Ceremony",       date: "25 September",     icon: reward, desc: "Winners announced & prizes distributed" },
];

const timelineTones = ["cyan", "blue", "orange", "purple", "blue"];
const timelinePattern = [
  { row: 1, slot: 1 },
  { row: 1, slot: 2 },
  { row: 1, slot: 3 },
  { row: 2, slot: 3 },
  { row: 2, slot: 2 },
  { row: 2, slot: 1 },
  { row: 3, slot: 1 },
  { row: 3, slot: 2 },
];

const timelineStops = timeline.map((item, index) => {
  const mapped = timelinePattern[index] ?? {
    row: Math.floor(index / 3) + 1,
    slot: (index % 3) + 1,
  };

  return {
    ...item,
    ...mapped,
    tone: timelineTones[index % timelineTones.length],
  };
});

const timelineRowCount = Math.max(...timelineStops.map((stop) => stop.row), 1);
const laneVariants = ["timeline-lane-top", "timeline-lane-middle", "timeline-lane-bottom"];

const timelineRows = Array.from({ length: timelineRowCount }, (_, rowIndex) => {
  const rowNumber = rowIndex + 1;
  return {
    variant: laneVariants[rowIndex] ?? "timeline-lane-middle",
    isLast: rowIndex === timelineRowCount - 1,
    items: timelineStops.filter((stop) => stop.row === rowNumber).sort((a, b) => a.slot - b.slot),
  };
});

const organizers = [
  { name: "Ayush Choudhary",  img: "AC",github: "https://github.com/ayushchoudhary",linkedin:"https://www.linkedin.com/in/ayushchoudhary" },
  { name: "Rahidul Khan",    img: "RK",github: "https://github.com/rahidulkhan",linkedin:"https://www.linkedin.com/in/rahidulkhan" },
  { name: "Nilotpal Das",    img: "ND",github: "https://github.com/nilotpal das",linkedin:"https://www.linkedin.com/in/nilotpal-das" },
  { name: "Ronit Banerjee", img: "RB",github: "https://github.com/ronitbanerjee",linkedin:"https://www.linkedin.com/in/ronitbanerjee" },
  { name: "Debankan Dutta", img: "DD",github: "https://github.com/debankandutta",linkedin:"https://www.linkedin.com/in/debankandutta" },
];

const prizes = [
  { place: "1st", amount: "₹2,000", emoji: "🥇", color: "gold",   rank: 1 },
  { place: "2nd", amount: "₹1,000", emoji: "🥈", color: "silver", rank: 2 },
  { place: "3rd", amount: "₹500",   emoji: "🥉", color: "bronze", rank: 3 },
];

const rules = [
  { text: "Team size: 2–4 members from any year (1st–4th)", icon: "👥" },
  { text: "All team members must be from the college",       icon: "🏫" },
  { text: "Teams must submit PPT before the deadline",       icon: "📅" },
  { text: "Hardware integration is mandatory, not optional", icon: "⚙️" },
  { text: "Plagiarism of code or ideas will lead to DQ",    icon: "🚫" },
  { text: "Teams can use open-source libraries & frameworks",icon: "📦" },
  { text: "Final project must be demonstrated live",         icon: "🎥" },
];

const submissionRequirements = [
  { title: "PPT Submission",       desc: "Mandatory presentation slides covering your project",  icon: "📊", tag: "Required", color: "orange" },
  { title: "GitHub Repository",    desc: "Optional: share your open source code repository",     icon: "💻", tag: "Optional", color: "blue" },
  { title: "Software Demo",        desc: "Optional: a working demo of your software component",  icon: "⚙️", tag: "Optional", color: "blue" },
  { title: "Hardware Demo Video",  desc: "Optional: showcase your hardware integration on video",icon: "🎥", tag: "Optional", color: "blue" },
];

const features = [
  { icon: "💡", title: "Innovation First",     desc: "Build solutions combining software intelligence with hardware creativity." },
  { icon: "⚙️", title: "Integration Focus",    desc: "Master embedded systems, IoT, and web platforms in one cohesive prototype." },
  { icon: "🚀", title: "Real Impact",          desc: "Cross-year teams (1st–4th year) working on projects that matter." },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="CODECRAFT — Where Software Meets Hardware. The ultimate hackathon at Ideal Institute of Engineering where builders blend code, circuits, and creativity." />
    <title>CODECRAFT | Where Software Meets Hardware</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="relative w-full">
      <!-- Ambient blobs -->
      <div class="fixed pointer-events-none opacity-10 w-[600px] h-[600px] bg-accent-blue top-0 left-0 rounded-full" style="filter: blur(120px);"></div>
      <div class="fixed pointer-events-none opacity-10 w-[700px] h-[700px] bg-accent-purple bottom-20 right-0 rounded-full" style="filter: blur(120px);"></div>
      <div class="fixed pointer-events-none opacity-10 w-[500px] h-[500px] bg-accent-orange top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full" style="filter: blur(120px);"></div>

      <!-- Cursor glow -->
      <div class="fixed pointer-events-none w-[400px] h-[400px] bg-accent-cyan rounded-full opacity-0" id="cursor-glow" style="filter: blur(80px); transform: translate(-50%, -50%); margin-left: -200px; margin-top: -200px;"></div>

      <!-- Page loader -->
      <div class="loader fixed inset-0 z-999 flex flex-col items-center justify-center gap-8 bg-gradient-to-b from-[#0c2238] via-[#071325] to-[#030812] transition-all duration-500" id="loader" aria-hidden="true" style="isolation: isolate;">
        <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.9%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>
        <div class="absolute rounded-full opacity-0" style="width: min(72vw, 420px); aspect-ratio: 1; background: radial-gradient(circle, rgba(0, 242, 254, 0.2) 0%, transparent 68%); animation: loader-pulse 2.8s ease-in-out infinite; z-index: -1;"></div>
        <img src={logoImg.src} alt="CodeCraft" class="w-[clamp(86px,11vw,124px)] opacity-0" style="filter: drop-shadow(0 0 24px rgba(0, 242, 254, 0.5)); transform: translateY(-80px) scale(0.72); animation: loader-entry 0.8s cubic-bezier(0.2, 0.7, 0.2, 1) 0.1s forwards, float 4s ease-in-out 1.1s infinite;" />
        <div class="relative opacity-0" style="width: min(48vw, 200px); height: 2px; border-radius: 999px; background: linear-gradient(90deg, transparent, rgba(0, 242, 254, 0.5), transparent); transform: scaleX(0); transform-origin: center; overflow: hidden; animation: loader-line-reveal 0.65s ease 0.4s forwards;">
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[rgba(255,255,255,0.86)] to-transparent" style="transform: translateX(-120%); animation: loader-sweep 1.35s linear 1.05s infinite;"></div>
        </div>
        <span class="text-[0.7rem] text-[rgba(214,244,255,0.7)] opacity-0" style="margin-top: -0.25rem; text-transform: uppercase; letter-spacing: 0.34em; transform: translateY(10px); animation: loader-caption 0.55s ease 0.72s forwards;">Booting CODECRAFT</span>
      </div>

      <Navbar />

      <main>

        <!-- ═══════════════════════════════════════════════════════ HERO -->
        <section class="relative min-h-screen flex items-center py-[100px] pb-16 overflow-hidden" id="home">
          <!-- Background -->
          <div class="absolute inset-0 -z-10 pointer-events-none">
            <div class="absolute inset-0" style="background-image: linear-gradient(rgba(0, 242, 254, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 242, 254, 0.05) 1px, transparent 1px); background-size: 50px 50px; mask-image: radial-gradient(circle at center, black 0%, transparent 80%);"></div>
            <div class="absolute w-[400px] h-[400px] bg-accent-blue -top-[100px] -left-[100px] rounded-full opacity-15" style="filter: blur(100px);"></div>
            <div class="absolute w-[400px] h-[400px] bg-accent-purple -bottom-[100px] -right-[100px] rounded-full opacity-15" style="filter: blur(100px);"></div>
            <div class="absolute w-[300px] h-[300px] bg-accent-orange top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-15" style="filter: blur(100px);"></div>
          </div>

          <!-- Content -->
          <div class="grid grid-cols-[0.8fr_1.2fr] gap-16 items-center w-[min(1280px,100%-3rem)] mx-auto">
            <!-- Hero text -->
            <div>
              <div class="inline-flex items-center gap-3 bg-[rgba(0,242,254,0.1)] border border-[rgba(0,242,254,0.2)] px-4 py-2 rounded-full font-orbitron text-[0.75rem] text-accent-cyan mb-8" style="letter-spacing: 0.1em;">
                <span class="w-[8px] h-[8px] bg-accent-cyan rounded-full" style="box-shadow: 0 0 10px var(--accent-cyan); animation: pulse 2s infinite;"></span>
                Ideal Institute of Engineering · IIE Tech Club
              </div>

              <h1 class="text-5xl lg:text-6xl leading-[0.9] m-0 mb-4 font-black" style="font-size: clamp(3rem, 10vw, 6rem); letter-spacing: -0.02em;">
                <span class="bg-gradient-cyan-blue bg-clip-text text-transparent">CODE</span><span class="text-text-main">CRAFT</span>
              </h1>

              <p class="font-orbitron text-2xl lg:text-3xl text-accent-blue mb-6" style="font-size: clamp(1.25rem, 3vw, 2rem);">Where Software Meets Hardware</p>

              <p class="text-text-muted text-lg max-w-[50ch] mb-12">
                Build the future by merging code and circuits. Join the ultimate hackathon where innovation meets engineering excellence.
              </p>

              <!-- Countdown -->
              <div class="inline-flex gap-6 mb-12 bg-[rgba(255,255,255,0.03)] px-8 py-6 rounded-lg border border-[rgba(255,255,255,0.05)]" id="countdown" aria-label="Time until event">
                <div class="flex flex-col items-center">
                  <span class="font-orbitron text-4xl font-bold text-text-main leading-tight" id="cd-days">--</span>
                  <span class="text-[0.75rem] text-text-muted mt-2" style="text-transform: uppercase; letter-spacing: 0.1em;">Days</span>
                </div>
                <div class="font-orbitron text-4xl text-accent-cyan opacity-50">:</div>
                <div class="flex flex-col items-center">
                  <span class="font-orbitron text-4xl font-bold text-text-main leading-tight" id="cd-hours">--</span>
                  <span class="text-[0.75rem] text-text-muted mt-2" style="text-transform: uppercase; letter-spacing: 0.1em;">Hours</span>
                </div>
                <div class="font-orbitron text-4xl text-accent-cyan opacity-50">:</div>
                <div class="flex flex-col items-center">
                  <span class="font-orbitron text-4xl font-bold text-text-main leading-tight" id="cd-mins">--</span>
                  <span class="text-[0.75rem] text-text-muted mt-2" style="text-transform: uppercase; letter-spacing: 0.1em;">Mins</span>
                </div>
                <div class="font-orbitron text-4xl text-accent-cyan opacity-50">:</div>
                <div class="flex flex-col items-center">
                  <span class="font-orbitron text-4xl font-bold text-text-main leading-tight" id="cd-secs">--</span>
                  <span class="text-[0.75rem] text-text-muted mt-2" style="text-transform: uppercase; letter-spacing: 0.1em;">Secs</span>
                </div>
              </div>

              <div class="flex flex-wrap gap-4 items-center mb-12">
                <button class="inline-flex items-center gap-3 bg-accent-cyan text-black px-8 py-4 rounded-full font-bold transition-all duration-300 hover:-translate-y-[3px]" type="button" data-open-register style="box-shadow: 0 0 30px rgba(0, 242, 254, 0.4); cursor: pointer;">
                  <span>Register Now</span>
                  <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="w-5 h-5"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="inline-flex items-center px-8 py-4 rounded-full bg-transparent border border-[rgba(255,255,255,0.1)] text-text-main font-semibold transition-all duration-300 hover:bg-[rgba(255,255,255,0.05)] hover:border-[rgba(255,255,255,0.2)]" type="button" data-scroll-to="#about" style="cursor: pointer;">
                  Learn More
                </button>
              </div>

              <!-- <div class="flex gap-12 items-center">
                <div class="flex flex-col">
                  <strong class="font-orbitron text-4xl text-text-main" data-counter="300" data-suffix="+">300+</strong>
                  <span class="text-text-muted text-sm" style="text-transform: uppercase; letter-spacing: 0.1em;">Participants</span>
                </div>
                <div class="w-px h-[30px] bg-[rgba(255,255,255,0.1)]"></div>
                <div class="flex flex-col">
                  <strong class="font-orbitron text-4xl text-text-main" data-counter="5" data-suffix="+">5+</strong>
                  <span class="text-text-muted text-sm" style="text-transform: uppercase; letter-spacing: 0.1em;">Days</span>
                </div>
                <div class="w-px h-[30px] bg-[rgba(255,255,255,0.1)]"></div>
                <div class="flex flex-col">
                  <strong class="font-orbitron text-4xl text-text-main">₹3.5K</strong>
                  <span class="text-text-muted text-sm" style="text-transform: uppercase; letter-spacing: 0.1em;">Prize Pool</span>
                </div>
              </div> -->
            </div>

            <!-- Hero visual: logo showcase -->
            <div class="relative flex justify-center">
              <div class="relative w-[500px] h-[500px] grid place-items-center">
                <div class="absolute w-[250px] h-[250px] rounded-full" style="background: radial-gradient(circle, rgba(0, 242, 254, 0.2) 0%, transparent 70%);"></div>
                <div class="absolute rounded-full border border-[rgba(0,242,254,0.2)] w-[280px] h-[280px]" style="animation: spin 20s linear infinite;"></div>
                <div class="absolute rounded-full border-dashed border border-[rgba(0,242,254,0.2)] w-[340px] h-[340px]" style="animation: spin 30s linear infinite reverse;"></div>
                <div class="absolute rounded-full border border-[rgba(0,242,254,0.2)] w-[400px] h-[400px] opacity-50" style="animation: spin 40s linear infinite;"></div>
                <img src={logoImg.src} alt="CodeCraft Logo" class="w-[260px] z-5" style="filter: drop-shadow(0 0 40px rgba(0, 242, 254, 0.5)); animation: float 6s ease-in-out infinite;" />
                <!-- Orbiting dots -->
                <div class="absolute rounded-full border border-[rgba(255,255,255,0.05)] w-[310px] h-[310px]" style="animation: spin 15s linear infinite;">
                  <span class="absolute top-[-5px] left-1/2 w-[10px] h-[10px] bg-accent-cyan rounded-full" style="box-shadow: 0 0 10px var(--accent-cyan);"></span>
                </div>
                <div class="absolute rounded-full border border-[rgba(255,255,255,0.05)] w-[370px] h-[370px]" style="animation: spin 25s linear infinite reverse;">
                  <span class="absolute top-[-5px] left-1/2 w-[10px] h-[10px] bg-accent-cyan rounded-full" style="box-shadow: 0 0 10px var(--accent-cyan);"></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Scroll indicator -->
          <!-- <div class="absolute bottom-8 left-1/2 -translate-x-1/2 pointer-events-none" aria-hidden="true">
            <div class="block w-6 h-10 border-2 border-text-muted rounded-full relative opacity-70">
              <div class="absolute top-2 left-1/2 w-[2px] h-2 bg-text-muted rounded-full -translate-x-1/2" style="animation: scroll-down 2s ease-in-out infinite;"></div>
            </div>
            <div class="block w-6 h-10 border-2 border-text-muted rounded-full relative opacity-70">
              <div class="absolute top-2 left-1/2 w-[2px] h-2 bg-text-muted rounded-full -translate-x-1/2" style="animation: scroll-down 2s ease-in-out infinite;"></div>
            </div>
          </div> -->
        </section>

        <!-- ══════════════════════════════════════════════════════ ABOUT -->
        <section class="min-h-screen flex flex-col items-center justify-center py-16 lg:py-32" id="about">
          <div class="w-[min(1280px,100%-3rem)] mx-auto">
            <div class="text-center mb-16 opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
              <p class="font-orbitron text-[0.75rem] text-accent-cyan mb-2" style="text-transform: uppercase; letter-spacing: 0.2em;">What is CODECRAFT?</p>
              <h2 class="text-5xl lg:text-6xl font-black m-0 mb-4" style="letter-spacing: -0.02em;">Build. Integrate. Innovate.</h2>
              <p class="text-text-muted text-lg max-w-[60ch] mx-auto">A hackathon where software meets hardware — teams build real, working projects that blend code with circuits.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
              {features.map((f) => (
                <div class="p-12 lg:p-10 bg-bg-alt rounded-lg border border-panel-border transition-all duration-400 relative overflow-hidden hover:-translate-y-[10px] hover:bg-[rgba(255,255,255,0.03)] hover:border-accent-cyan">
                  <div class="text-4xl mb-6">{f.icon}</div>
                  <h3 class="text-2xl mb-4">{f.title}</h3>
                  <p class="text-text-muted m-0">{f.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- ══════════════════════════════════════════════════════ PRIZES -->
        <section class="min-h-screen flex flex-col items-center justify-center py-16 lg:py-32 relative" id="prizes">
          <div class="w-[min(1280px,100%-3rem)] mx-auto">
            <div class="text-center opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
              <p class="font-orbitron text-[0.75rem] text-accent-cyan " style="text-transform: uppercase; letter-spacing: 0.2em;">Rewards</p>
              <h2 class="text-5xl lg:text-6xl font-black m-0 mb-4" style="letter-spacing: -0.02em;">Prize Pool</h2>
              <p class="text-text-muted text-lg max-w-[60ch] mx-auto">Total Prize Pool: ₹3,500 + Certificates for all participants</p>
            </div>

       
            </div>

            <div class="grid grid-cols-3 gap-10 items-end max-w-4xl mx-auto pt-16 opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
              {prizes.map((p) => (
                <div class={`relative p-12 lg:p-8 bg-bg-alt rounded-lg border transition-all duration-400 flex flex-col items-center text-center hover:-translate-y-[5px] hover:border-[rgba(255,255,255,0.2)] ${
                  p.rank === 1 ? 'h-[380px] order-2 border-[#fbbf2466] bg-gradient-to-b from-[rgba(251,191,36,0.05)] to-transparent' :
                  p.rank === 2 ? 'h-[320px] order-1 border-[#94a3b866]' :
                  'h-[280px] order-3 border-[#b4530966]'
                }`} data-rank={p.rank}>
                  <div class="absolute inset-0 opacity-0"></div>
                  <div class="text-5xl mb-4">{p.emoji}</div>
                  <div class="font-orbitron text-sm text-text-muted mb-2" style="text-transform: uppercase;">{p.place} Place</div>
                  <div class={`font-orbitron text-4xl font-black ${p.rank === 1 ? 'text-[#fbbf24]' : 'text-text-main'}`}>{p.amount}</div>
                  <div></div>
                </div>
              ))}
            </div>

            <p class="text-center text-text-muted mt-12 opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">🏆 Plus certificates and recognition for all participants</p>
          </div>
        </section>

        <!-- ══════════════════════════════════════════════════════ TIMELINE -->
        <section class="min-h-screen flex flex-col items-center justify-center py-16 lg:py-32 relative" id="timeline">
          <div class="w-[min(1280px,100%-3rem)] mx-auto">
            <div class="text-center mb-16 opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
              <p class="font-orbitron text-[0.75rem] text-accent-cyan mb-2" style="text-transform: uppercase; letter-spacing: 0.2em;">Schedule</p>
              <h2 class="text-5xl lg:text-6xl font-black m-0 mb-4" style="letter-spacing: -0.02em;">Event Timeline</h2>
              <p class="text-text-muted text-lg max-w-[60ch] mx-auto">Key dates to keep in your calendar</p>
            </div>

            <div class="timeline-road opacity-0 transform translate-y-[30px] transition-all duration-[0.8s] reveal" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
              {timelineRows.map((row) => (
                <div class={`timeline-lane ${row.variant} ${row.isLast ? 'timeline-lane-last' : 'timeline-lane-continues'}`}>
                  {row.items.map((item) => {
                    const iconValue = item.icon;
                    const isStringIcon = typeof iconValue === "string";
                    const isEmojiIcon = isStringIcon && [...iconValue].length <= 3;
                    const IconComponent = item.icon;

                    return (
                      <article class={`timeline-stop tone-${item.tone}`} style={`--slot: ${item.slot};`}>
                        <span class="timeline-node">
                          <span class="timeline-emoji">
                            {isEmojiIcon
                              ? iconValue
                              : isStringIcon
                                ? <img src={iconValue} alt="" loading="lazy" />
                                : <IconComponent />}
                          </span>
                        </span>
                        <div class="timeline-copy">
                          <h3>{item.title}</h3>
                          <p class="timeline-date">{item.date}</p>
                          <p class="timeline-desc">{item.desc}</p>
                        </div>
                      </article>
                    );
                  })}
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- ══════════════════════════════════════════════════════ RULES -->
