const submissionRequirements = [
  {
    title: "PPT Submission",
    desc: "Mandatory presentation slides covering your project",
    icon: "📊",
    tag: "Required",
    color: "orange",
  },
  {
    title: "GitHub Repository",
    desc: "Optional: share your open source code repository",
    icon: "💻",
    tag: "Optional",
    color: "blue",
  },
  {
    title: "Software Demo",
    desc: "Optional: a working demo of your software component [It can be MVP link or youtube video link]",
    icon: "⚙️",
    tag: "Optional",
    color: "blue",
  },
  {
    title: "Hardware Demo Video",
    desc: "Optional: showcase your hardware integration on video , The video must be uploaded to YouTube and the link shared",
    icon: "🎥",
    tag: "Optional",
    color: "blue",
  },
];

const features = [
  {
    icon: "💡",
    num: "01",
    title: "Innovation First",
    desc: "Build solutions combining software intelligence with hardware creativity.",
  },
  {
    icon: "⚙️",
    num: "02",
    title: "Integration Focus",
    desc: "Master embedded systems, IoT, and web platforms in one cohesive prototype.",
  },
  {
    icon: "🚀",
    num: "03",
    title: "Real Impact",
    desc: "Cross-year teams (1st–4th year) working on projects that matter.",
  },
];

const siteUrl = "https://iie-codecraft.vercel.app";
const pageTitle = "CODECRAFT 2026 | Hardware-First Hackathon by IIE Tech Club";
const pageDescription =
  "Register for CODECRAFT 2026, the IIE Tech Club hackathon at Ideal Institute of Engineering where student teams build software and hardware prototypes with live demos, prizes, and certificates.";
const pageKeywords =
  "CODECRAFT, CODECRAFT 2026, IIE Tech Club, Ideal Institute of Engineering hackathon, hardware hackathon, software hardware project competition, student hackathon";
const socialImage = `${siteUrl}/CodeCraft.png`;

const eventStructuredData = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: "CODECRAFT 2026",
  description: pageDescription,
  url: siteUrl,
  image: [socialImage],
  startDate: "2026-09-21T09:00:00+05:30",
  endDate: "2026-09-25T18:00:00+05:30",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  eventStatus: "https://schema.org/EventScheduled",
  keywords: pageKeywords,
  location: {
    "@type": "Place",
    name: "Ideal Institute of Engineering",
    address: "Ideal Institute of Engineering campus",
  },
  organizer: {
    "@type": "Organization",
    name: "IIE Tech Club",
    url: siteUrl,
  },
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta name="author" content="IIE Tech Club" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#020811" />
    <meta name="format-detection" content="telephone=yes" />
    <link rel="canonical" href={siteUrl} />
    <title>{pageTitle}</title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="CODECRAFT" />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="352" />
    <meta property="og:image:height" content="236" />
    <meta
      property="og:image:alt"
      content="CODECRAFT hardware-first hackathon logo"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta
      name="twitter:image:alt"
      content="CODECRAFT hardware-first hackathon logo"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/CodeCraft.png" />
    <link rel="apple-touch-icon" href="/CodeCraft.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" as="image" href={logoImg.src} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(eventStructuredData)}
    />
  </head>

  <body>
    <!-- ── Page shell ── -->
    <div class="page-shell" id="page-shell">
      <!-- Ambient background orbs -->
      <div
        class="ambient-bg"
        aria-hidden="true"
        style="position:fixed;inset:0;pointer-events:none;z-index:0;"
      >
        <div
          style="position:absolute;width:700px;height:700px;background:#4facfe;top:-100px;left:-200px;border-radius:50%;filter:blur(140px);opacity:0.06;"
        >
        </div>
        <div
          style="position:absolute;width:700px;height:700px;background:#8e2de2;bottom:-100px;right:-150px;border-radius:50%;filter:blur(140px);opacity:0.06;"
        >
        </div>
        <div
          style="position:absolute;width:500px;height:500px;background:#00f2fe;top:40%;left:55%;border-radius:50%;filter:blur(140px);opacity:0.04;transform:translate(-50%,-50%);"
        >
        </div>
      </div>

      <CustomCursor />
      <Loader logoSrc={logoImg.src} />

      <Navbar />

      <main id="main-content">
        <!-- ══════════════════════════════════════════════ HERO ══ -->
        <section class="hero" id="home" aria-label="Hero">
          <div class="hero-grid-bg" aria-hidden="true"></div>

          <div class="wrap" style="position:relative;z-index:2;">
            <div class="hero-content">
              <!-- Left text column -->
              <div class="hero-text">
                <div class="hero-eyebrow">
                  <span class="eyebrow-dot" aria-hidden="true"></span>
                  IIE Tech Club · Ideal Institute of Engineering
                </div>

                <h1 class="hero-heading">
                  <span class="hero-heading-code">CODE</span><span
                    class="hero-heading-craft">CRAFT</span
                  >
                </h1>

                <p class="hero-tagline">Where Software Meets Hardware</p>

                <p
                  class="hero-desc"
                  style="color:var(--c-cyan); 
  text-shadow: 0 0 15px rgba(0, 242, 254, 0.4);"
                >
                  Bridge the gap between virtual logic and physical circuits.
                  Join the ultimate hardware-first hackathon where raw code
                  meets real engineering.
                </p>
                <!-- Countdown -->
                <div
                  class="countdown"
                  id="countdown"
                  aria-label="Time until event"
                >
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-days">--</span>
                    <span class="cd-lbl">Days</span>
                  </div>
                  <span class="cd-sep" aria-hidden="true">:</span>
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-hours">--</span>
                    <span class="cd-lbl">Hours</span>
                  </div>
                  <span class="cd-sep" aria-hidden="true">:</span>
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-mins">--</span>
                    <span class="cd-lbl">Mins</span>
                  </div>
                  <span class="cd-sep" aria-hidden="true">:</span>
                  <div class="cd-unit">
                    <span class="cd-val" id="cd-secs">--</span>
                    <span class="cd-lbl">Secs</span>
                  </div>
                </div>

                <!-- CTAs -->
                <div class="hero-actions">
                  <button
                    type="button"
                    class="btn-primary"
                    id="hero-register-btn"
                    data-auth-trigger
                  >
                    Register Now
                    <svg
                      viewBox="0 0 20 20"
                      fill="none"
                      aria-hidden="true"
                      style="width:16px;height:16px;"
                    >
                      <path
                        d="M4 10h12M12 5l5 5-5 5"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </button>
                  <button
                    class="btn-ghost"
                    type="button"
                    data-scroll-to="#about"
                    id="hero-learn-btn"
                  >
                    Learn More ↓
                  </button>
                </div>
              </div>

              <!-- Right visual column -->
              <div class="hero-visual" aria-hidden="true">
                <div class="cyber-station">
                  <!-- Abstract Circuit Lines -->
                  <div class="circuit-bg">
                    <svg viewBox="0 0 400 400" preserveAspectRatio="none">
                      <path
                        d="M 0 50 L 150 50 L 200 100 L 400 100"
                        class="circuit-path p1"></path>
                      <path
                        d="M 400 300 L 250 300 L 200 250 L 0 250"
                        class="circuit-path p2"></path>
                      <path
                        d="M 100 0 L 100 120 L 150 170 L 150 400"
                        class="circuit-path p3"></path>
                      <path
                        d="M 300 400 L 300 150 L 250 100"
                        class="circuit-path p4"></path>

                      <circle cx="150" cy="50" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="200" cy="100" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="250" cy="300" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="200" cy="250" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="100" cy="120" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="150" cy="170" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="250" cy="100" r="4" class="circuit-node"
                      ></circle>
                      <circle cx="300" cy="150" r="4" class="circuit-node"
                      ></circle>
                    </svg>
                  </div>

                  <!-- Hardware Microcontroller -->
                  <div class="mcu-board">
                    <div class="mcu-core">
                      <img
                        src={logoImg.src}
                        width={logoImg.width}
                        height={logoImg.height}
                        alt="CodeCraft hardware hackathon logo"
                        class="mcu-logo"
                        decoding="async"
                        fetchpriority="high"
                      />
                    </div>
                    <div class="mcu-pins top">
                      <i></i><i></i><i></i><i></i><i></i><i></i>
                    </div>
                    <div class="mcu-pins bottom">
                      <i></i><i></i><i></i><i></i><i></i><i></i>
                    </div>
                    <div class="mcu-pins left">
                      <i></i><i></i><i></i><i></i>
                    </div>
                    <div class="mcu-pins right">
                      <i></i><i></i><i></i><i></i>
                    </div>

                    <div class="mcu-led led-tx"></div>
                    <div class="mcu-led led-rx"></div>
                  </div>

                  <!-- Glass Terminal overlapping -->
                  <div class="glass-terminal">
                    <div class="term-header">
                      <div class="term-btns">
                        <span></span><span></span><span></span>
                      </div>
                      <div class="term-title">bash - root@codecraft</div>
                    </div>
                    <div class="term-body">
                      <div class="t-line">
                        <span class="t-prompt">root@codecraft:~#</span> ./init_hardware.sh
                      </div>
                      <div class="t-line t-process">
                        [ OK ] Booting neural subsystem...
                      </div>
                      <div class="t-line t-process">
                        [ OK ] Linking code to logic gates...
                      </div>
                      <div class="t-line t-process">
                        [ OK ] Hardware synced successfully!
                      </div>
                      <div class="t-line">
                        <span class="t-prompt">root@codecraft:~#</span> execute_hackathon.exe
                      </div>
                      <div class="t-line t-success">
                        &gt;&gt; COMPILING INNOVATION...
                      </div>
                      <div class="t-cursor"></div>
                    </div>
                  </div>

                  <!-- Floating HUD elements -->
                  <div class="hud-box hud-tr">
                    <span class="hud-lbl">SYS.STATE</span>
                    <span class="hud-val pulse-val">OPTIMAL</span>
                  </div>

                  <div class="hud-box hud-bl">
                    <span class="hud-lbl">LATENCY</span>
                    <span class="hud-val">12ms</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ── Stats bar ── -->
        <div class="stats-bar" role="region" aria-label="Event stats">
          <div class="wrap stats-bar-inner">
            <div class="stat-item">
              <span class="stat-value" data-counter="3500" data-suffix="₹"
                >₹3500</span
              >
              <span class="stat-label">Prize Pool</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value" data-counter="4" data-suffix="">4</span>
              <span class="stat-label">Max Team Size</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value" data-counter="26" data-suffix=" Days"
                >26 Days</span
              >
              <span class="stat-label">Event Duration</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Live Demo Required</span>
            </div>
          </div>
        </div>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ ABOUT ══ -->
        <section class="section" id="about" aria-labelledby="about-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">What is CODECRAFT?</p>
              <h2 class="section-title" id="about-title">
                Build. Integrate. Innovate.
              </h2>
              <p class="section-sub">
                A hackathon where software meets hardware — teams build real,
                working projects that blend code with circuits.
              </p>
            </div>

            <div class="core-modules-grid reveal-stagger">
              {
                features.map((f, i) => (
                  <div class="core-module" data-index={i + 1}>
                    <div class="cm-glow" />
                    <div class="cm-border-top" />
                    <div class="cm-border-bottom" />
                    <div class="cm-header">
                      <span class="cm-id">
                        SYS_CORE // {String(i + 1).padStart(2, "0")}
                      </span>
                      <span class="cm-status">ONLINE</span>
                    </div>
                    <div class="cm-body">
                      <div class="cm-icon-box">
                        <span class="cm-icon">{f.icon}</span>
                      </div>
                      <div class="cm-content">
                        <h3 class="cm-title">{f.title}</h3>
                        <p class="cm-desc">{f.desc}</p>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ PRIZES ══ -->
        <section class="section" id="prizes" aria-labelledby="prizes-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">Rewards</p>
              <h2 class="section-title" id="prizes-title">Prize Pool</h2>
              <p class="section-sub">
                Total Prize Pool: ₹3,500 + Certificates for all participants
              </p>
            </div>

            <div class="bounty-podium reveal">
              {
                prizes.map((p) => (
                  <div class={`bounty-card rank-${p.rank}`} data-rank={p.rank}>
                    <div class="bc-glitch-layer" aria-hidden="true" />
                    <div class="bc-content">
                      <div class="bc-rank-badge">0{p.rank}</div>
                      <div class="bc-medal">{p.emoji}</div>
                      <div class="bc-place">{p.place} BOUNTY</div>
                      <div class="bc-amount">{p.amount}</div>
                      <div class="bc-hex-bg" />
                    </div>
                  </div>
                ))
              }
            </div>

            <p
              class="reveal"
              style="text-align:center;color:var(--c-muted);font-size:0.9rem;margin-top:2rem;"
            >
              🏆 All participants receive digital certificates of participation
            </p>
          </div>
        </section>

        <div class="section-divider"></div>

        <!-- ══════════════════════════════════════════════ TIMELINE ══ -->
        <section class="section" id="timeline" aria-labelledby="timeline-title">
          <div class="wrap">
            <div class="section-header reveal">
              <p class="section-kicker">Schedule</p>
              <h2 class="section-title" id="timeline-title">Event Timeline</h2>
              <p class="section-sub">Key dates to keep in your calendar</p>
            </div>

            <!-- Desktop horizontal pipeline -->
            <div class="codecraft-timeline-hz reveal hide-on-mobile">
              <div class="hz-track" aria-hidden="true">
                <span class="hz-track-seg hz-zig hz-zig-1"></span>
                <span class="hz-track-seg hz-zig hz-zig-2"></span>
                <span class="hz-track-seg hz-zig hz-zig-3"></span>
                <span class="hz-track-seg hz-zig hz-zig-4"></span>
                <span class="hz-track-seg hz-zig hz-zig-5"></span>
              </div>
              <div class="hz-nodes">
                {
                  timelineStops.map((item, index) => {
                    const isUp = index % 2 === 0;
                    const iconValue = item.icon;
                    const isStringIcon = typeof iconValue === "string";
                    const isEmojiIcon =
                      isStringIcon && [...iconValue].length <= 3;
                    const IconComponent = item.icon;

                    return (
                      <div class={`hz-item ${isUp ? "hz-up" : "hz-down"}`}>
                        <article class="hz-content">
                          <p class="hz-date">{item.date}</p>
                          <h3 class="hz-title">{item.title}</h3>
                          <p class="hz-desc">{item.desc}</p>
                        </article>
                        <div class={`hz-dot tone-${item.tone}`}>
                          <div class="hz-icon">
                            {isEmojiIcon ? (
                              <span>{iconValue}</span>
                            ) : isStringIcon ? (
                              <img src={iconValue} alt="" loading="lazy" />
                            ) : (
                              <IconComponent />
                            )}
                          </div>
                        </div>
                      </div>
                    );
                  })
                }
              </div>
            </div>

            <!-- Mobile vertical timeline -->
            <div class="timeline-mobile reveal show-on-mobile">
              {
                timelineStops.map((item) => {
                  const iconValue = item.icon;
                  const isStringIcon = typeof iconValue === "string";
                  const isEmojiIcon =
                    isStringIcon && [...iconValue].length <= 3;
                  const IconComponent = item.icon;
                  return (
                    <div class="tl-stop">
                      <div class={`tl-node tone-${item.tone}`}>
                        {isEmojiIcon ? (
