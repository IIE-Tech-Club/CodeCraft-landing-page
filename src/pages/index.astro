const prizes = [
  { place: "1st", amount: "₹2,000", emoji: "🥇", rank: 1 },
  { place: "2nd", amount: "₹1,000", emoji: "🥈", rank: 2 },
  { place: "3rd", amount: "₹500", emoji: "🥉", rank: 3 },
];

const rules = [
  { text: "Team size: 2–4 members from any year (1st–4th)", icon: "👥" },
  { text: "All team members must be from the college", icon: "🏫" },
  { text: "Teams must submit PPT before the deadline", icon: "📅" },
  { text: "Hardware integration is mandatory, not optional", icon: "⚙️" },
  {
    text: "Ideas must be original and not copied from existing projects",
