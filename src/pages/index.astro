    <script is:inline>
      // ── Scroll-to
      document.querySelectorAll("[data-scroll-to]").forEach((b) => {
        b.addEventListener("click", () => {
          const el = document.querySelector(b.getAttribute("data-scroll-to"));
          el?.scrollIntoView({ behavior: "smooth" });
        });
      });

      // ── Scroll reveal
      const ro = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (en.isIntersecting) {
              en.target.classList.add("in-view");
              ro.unobserve(en.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      document
        .querySelectorAll(".reveal, .reveal-stagger")
        .forEach((el) => ro.observe(el));

      // ── Counter animation
      const animateCount = (node) => {
        const target = +node.dataset.counter || 0;
        const suffix = node.dataset.suffix || "";
        const dur = 1400,
          start = performance.now();
        const tick = (now) => {
          const p = Math.min((now - start) / dur, 1);
          node.textContent =
            Math.round(target * (1 - Math.pow(1 - p, 3))) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      const co = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (en.isIntersecting) {
              animateCount(en.target);
              co.unobserve(en.target);
            }
          });
        },
        { threshold: 0.5 },
      );
      document
        .querySelectorAll("[data-counter]")
        .forEach((el) => co.observe(el));

      // ── Countdown to event (21 Sep 2026)
      const target = new Date("2026-09-21T09:00:00");
      const pad = (n) => String(n).padStart(2, "0");
      const updateCD = () => {
        const diff = target - Date.now();
        if (diff <= 0) {
          document.getElementById("countdown")?.remove();
          return;
        }
        const s = Math.floor(diff / 1000);
        document.getElementById("cd-days").textContent = pad(
          Math.floor(s / 86400),
        );
        document.getElementById("cd-hours").textContent = pad(
          Math.floor((s % 86400) / 3600),
        );
        document.getElementById("cd-mins").textContent = pad(
          Math.floor((s % 3600) / 60),
        );
        document.getElementById("cd-secs").textContent = pad(s % 60);
      };
      updateCD();
      setInterval(updateCD, 1000);
    </script>
    <script>
      import {
        googleLogin,
        subscribeToAuthChanges,
      } from "../services/authService";
      import type { User } from "firebase/auth";

      // Automatic redirect if already logged in
      subscribeToAuthChanges((user: User | null) => {
        if (user) {
          window.location.href = "/dashboard";
        }
      });

      document
        .querySelectorAll<HTMLElement>("[data-auth-trigger]")
        .forEach((btn) => {
          btn.addEventListener("click", async (e) => {
            e.preventDefault();

            const ogText = btn.innerHTML;
            btn.innerHTML = "Authenticating...";
            btn.style.pointerEvents = "none";

            const { user, error } = await googleLogin();

            if (user) {
              window.location.href = "/dashboard";
            } else {
              console.error("Authentication failed:", error);
              btn.innerHTML = ogText;
              btn.style.pointerEvents = "auto";
              alert(
                "Authentication failed, please check your network and try again.",
              );
            }
          });
        });
    </script>
